@page "/session/vysledky"
@page "/session/vysledky/{SessionId:guid}"
@inject HttpClient HttpClient
@inject TeamSessionLocalStore TeamSessionLocalStore

<PageTitle>Výsledky hry</PageTitle>

<h1>Výsledky hry</h1>

@if (!string.IsNullOrWhiteSpace(infoMessage))
{
    <div class="alert alert-info" role="alert">@infoMessage</div>
}

@if (apiError is not null)
{
    <div class="alert alert-danger" role="alert">@apiError.Message</div>
}

@if (!SessionId.HasValue)
{
    <div class="alert alert-warning" role="alert">Chybí ID session. Použijte odkaz z herní obrazovky.</div>
}
else if (identity is null)
{
    <div class="alert alert-warning" role="alert">
        Chybí uložená týmová identita pro tuto session.
    </div>
    <a class="btn btn-outline-primary" href="/tym/pripojeni">Přejít na připojení týmu</a>
}
else if (results is null)
{
    <button class="btn btn-primary" type="button" disabled="@isLoading" @onclick="LoadResultsAsync">
        @(isLoading ? "Načítám..." : "Načíst výsledky")
    </button>
}
else
{
    <section class="card mb-4">
        <div class="card-body">
            <h2 class="h5 mb-3">Finální pořadí</h2>

            @if (results.Results.Count == 0)
            {
                <p class="mb-0">Žádné výsledky nejsou k dispozici.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped mb-0">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Tým</th>
                                <th>Body</th>
                                <th>Správně</th>
                                <th>Celkový čas (s)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in results.Results)
                            {
                                var isMyTeam = r.TeamId == identity.TeamId;
                                var isWinner = r.Rank == 1;
                                <tr class="@(isMyTeam ? "table-primary" : "")">
                                    <td><strong>@r.Rank</strong></td>
                                    <td>@r.TeamName @(isWinner ? "⭐" : "")</td>
                                    <td>@r.Score</td>
                                    <td>@r.CorrectCount</td>
                                    <td>@FormatTimeSeconds(r.TotalCorrectResponseTimeMs)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </section>

    @if (correctAnswers is not null)
    {
        <section class="card mb-4">
            <div class="card-body">
                <h2 class="h5 mb-3">Správné odpovědi</h2>

                @if (correctAnswers.CorrectAnswers.Count == 0)
                {
                    <p class="mb-0">Žádné otázky nejsou k dispozici.</p>
                }
                else
                {
                    @foreach (var q in correctAnswers.CorrectAnswers)
                    {
                        <div class="mb-3 p-3 border rounded">
                            <p class="mb-1"><strong>Otázka @(q.OrderIndex + 1):</strong> @q.QuestionText</p>
                            <ul class="mb-1">
                                @foreach (var o in q.Options)
                                {
                                    var isCorrect = o.OptionKey == q.CorrectOption;
                                    var isSelectedWrong = q.TeamSelectedOption.HasValue && q.TeamSelectedOption != q.CorrectOption && o.OptionKey == q.TeamSelectedOption.Value;
                                    <li class="@(isCorrect ? "text-success fw-bold" : isSelectedWrong ? "text-danger fw-bold" : "")">
                                        @o.OptionKey — @o.Text @(isCorrect ? "✓" : isSelectedWrong ? "✗" : "")
                                    </li>
                                }
                            </ul>
                            <p class="mb-0 text-muted">Správná odpověď: <strong>@q.CorrectOption</strong></p>
                        </div>
                    }
                }
            </div>
        </section>
    }

    <a class="btn btn-outline-primary" href="/">Zpět na úvod</a>
}

@code {
    [Parameter]
    public Guid? SessionId { get; set; }

    [SupplyParameterFromQuery]
    public Guid? TeamId { get; set; }

    private StoredTeamIdentity? identity;
    private SessionResultsResponse? results;
    private CorrectAnswersResponse? correctAnswers;
    private ApiErrorResponse? apiError;
    private string? infoMessage;
    private bool isLoading;

    protected override async Task OnParametersSetAsync()
    {
        apiError = null;
        infoMessage = null;

        if (!SessionId.HasValue)
        {
            return;
        }

        identity = await TeamSessionLocalStore.FindIdentityAsync(SessionId.Value, TeamId);
        if (identity is null)
        {
            return;
        }

        await LoadResultsAsync();

        if (results is not null)
        {
            await LoadCorrectAnswersAsync();
        }
    }

    private async Task LoadResultsAsync()
    {
        if (!SessionId.HasValue || identity is null)
        {
            return;
        }

        isLoading = true;
        apiError = null;

        using var request = new HttpRequestMessage(HttpMethod.Get, $"/api/sessions/{SessionId.Value}/results?teamId={identity.TeamId}");
        request.Headers.Add("X-Team-Reconnect-Token", identity.TeamReconnectToken);

        using var response = await HttpClient.SendAsync(request);
        if (response.IsSuccessStatusCode)
        {
            results = await response.Content.ReadFromJsonAsync<SessionResultsResponse>();
        }
        else
        {
            results = null;
            apiError = await ReadApiErrorAsync(response);
        }

        isLoading = false;
    }

    private async Task LoadCorrectAnswersAsync()
    {
        if (!SessionId.HasValue || identity is null)
        {
            return;
        }

        using var request = new HttpRequestMessage(HttpMethod.Get, $"/api/sessions/{SessionId.Value}/correct-answers?teamId={identity.TeamId}");
        request.Headers.Add("X-Team-Reconnect-Token", identity.TeamReconnectToken);

        using var response = await HttpClient.SendAsync(request);
        if (response.IsSuccessStatusCode)
        {
            correctAnswers = await response.Content.ReadFromJsonAsync<CorrectAnswersResponse>();
        }
        else
        {
            correctAnswers = null;
        }
    }

    private string FormatTimeSeconds(long totalMs)
    {
        var seconds = totalMs / 1000.0;
        if (results is not null && HasDuplicateWholeSeconds(results.Results))
        {
            return seconds.ToString("F3");
        }
        return seconds.ToString("F0");
    }

    private static bool HasDuplicateWholeSeconds(IReadOnlyList<SessionResultDto> items)
    {
        var wholeSeconds = items.Select(r => (long)(r.TotalCorrectResponseTimeMs / 1000.0));
        return wholeSeconds.Count() != wholeSeconds.Distinct().Count();
    }

    private static async Task<ApiErrorResponse> ReadApiErrorAsync(HttpResponseMessage response)
    {
        var error = await response.Content.ReadFromJsonAsync<ApiErrorResponse>();
        return error ?? new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Načtení výsledků selhalo.");
    }
}
