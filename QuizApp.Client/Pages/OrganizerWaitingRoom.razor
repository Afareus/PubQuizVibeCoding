@page "/organizator/session/cekarna"
@page "/organizator/session/cekarna/{SessionId:guid}"
@using Microsoft.AspNetCore.SignalR.Client
@implements IAsyncDisposable
@inject HttpClient HttpClient
@inject OrganizerQuizLocalStore OrganizerQuizLocalStore
@inject IJSRuntime JSRuntime
@inject ActiveSessionState ActiveSessionState

<PageTitle>@PageHeading</PageTitle>

<h1>@PageHeading</h1>

<p class="text-muted">Realtime: @(isRealtimeConnected ? "připojeno" : "odpojeno")@(isFallbackPolling ? " (záložní polling aktivní)" : string.Empty)</p>

@if (!string.IsNullOrWhiteSpace(infoMessage))
{
    <div class="alert alert-info" role="alert">@infoMessage</div>
}

@if (apiError is not null)
{
    <div class="alert alert-danger" role="alert">@apiError.Message</div>
}

@if (snapshot is not null)
{
    @if (IsSessionActive && snapshot.CurrentQuestion is not null)
    {
        <section class="card mb-4">
            <div class="card-body">
                <h2 class="h5 fw-normal mb-2">Otázka číslo: @((snapshot.CurrentQuestionIndex ?? 0) + 1)</h2>
                <p class="mb-2"><strong>@snapshot.CurrentQuestion.Text</strong></p>

                @if (UsesQuestionTimer)
                {
                    @if (remainingSeconds > 0)
                    {
                        <p class="mb-2 fs-5"><strong>⏱ Zbývá:</strong> @remainingSeconds s</p>
                    }
                    else
                    {
                        <p class="mb-2 fs-5 text-danger"><strong>⏱ Čas vypršel</strong></p>
                    }
                }

                @if (snapshot.CurrentQuestion.QuestionType == QuestionType.MultipleChoice)
                {
                    <div class="d-grid gap-2 mb-3">
                        @foreach (var option in snapshot.CurrentQuestion.Options.OrderBy(option => option.OptionKey))
                        {
                            var isCorrectOptionRevealed = IsCurrentQuestionAnswerRevealed
                                && revealedCorrectOption.HasValue
                                && option.OptionKey == revealedCorrectOption.Value;

                            <button class="btn @(isCorrectOptionRevealed ? "btn-success" : "btn-outline-primary") text-start" type="button" disabled>
                                <strong>@option.OptionKey</strong> — @option.Text
                            </button>
                        }
                    </div>
                }
                else
                {
                    <p class="mb-3 text-muted">Bod získá nejbližší odpověď.</p>

                    @if (IsCurrentQuestionAnswerRevealed)
                    {
                        <p class="mb-3 text-success fw-semibold"><strong>Správná odpověď:</strong> @FormatDecimal(revealedCorrectNumericValue)</p>
                    }
                }

                @if (UsesQuestionTimer)
                {
                    <button class="btn btn-warning" type="button" disabled="@isLoading" @onclick="TogglePauseAsync">@PauseButtonText</button>
                }
                else
                {
                    <div class="d-flex flex-wrap gap-2">
                        <button class="btn btn-info" type="button" disabled="@isLoading" @onclick="ShowCorrectAnswerAsync">Zobrazit správnou odpověď</button>
                        <button class="btn btn-warning" type="button" disabled="@isLoading" @onclick="AdvanceSessionAsync">@AdvanceButtonText</button>
                    </div>
                }
            </div>
        </section>
    }

    <section class="card mb-4">
        <div class="card-body">
            <h2 class="h5 mb-3">Detail hry</h2>
            <p class="mb-1"><strong>Název kvízu:</strong> @(string.IsNullOrWhiteSpace(storedQuizName) ? "(neznámý název)" : storedQuizName)</p>
            @if (snapshot.Status == SessionStatus.Waiting)
            {
                <div class="alert alert-primary mb-2" role="alert">
                    <div class="small text-uppercase fw-semibold">Join kód</div>
                    <div class="fs-3 fw-bold"><code class="fs-3">@snapshot.JoinCode</code></div>
                </div>
            }
            <p class="mb-3"><strong>Stav:</strong> @snapshot.Status</p>

            <div class="d-flex gap-2 mb-3">
                @if (snapshot.Status == SessionStatus.Waiting)
                {
                    <button class="btn btn-success" type="button" disabled="@isLoading" @onclick="StartSessionInSelectedModeAsync">
                        @(isLoading ? "Provádím..." : StartButtonText)
                    </button>
                }

                @if (snapshot.Status == SessionStatus.Finished)
                {
                    <a class="btn btn-primary" href="@($"/organizator/session/vysledky/{snapshot.SessionId}?quizId={snapshot.QuizId}")">
                        Zobrazit výsledky a správné odpovědi
                    </a>
                }
            </div>

            <h3 class="h6">Připojené týmy (@snapshot.Teams.Count)</h3>

            @if (snapshot.Teams.Count == 0)
            {
                <p class="mb-0">Zatím není připojen žádný tým.</p>
            }
            else
            {
                <ul class="mb-0">
                    @foreach (var team in snapshot.Teams)
                    {
                        <li>@team.TeamName <span class="text-muted">(@ToPresenceLabel(team.PresenceStatus))</span></li>
                    }
                </ul>
            }

            @if (snapshot.Status is SessionStatus.Waiting or SessionStatus.Running or SessionStatus.Paused)
            {
                <div class="mt-3">
                    <button class="btn btn-outline-danger" type="button" disabled="@isLoading" @onclick="CancelSessionAsync">
                        @(isLoading ? "Provádím..." : "Zrušit hru")
                    </button>
                </div>
            }

        </div>
    </section>
}

@code {
    [Parameter]
    public Guid? SessionId { get; set; }

    [SupplyParameterFromQuery]
    public Guid? QuizId { get; set; }

    [SupplyParameterFromQuery(Name = "startMode")]
    public string? StartMode { get; set; }

    private string sessionIdInput = string.Empty;
    private string? storedOrganizerToken;
    private string? storedQuizName;
    private string? infoMessage;
    private bool isLoading;
    private bool isRealtimeConnected;

    private ApiErrorResponse? apiError;
    private OrganizerSessionSnapshotResponse? snapshot;
    private HubConnection? hubConnection;
    private Guid? realtimeSessionId;
    private Guid? autoLoadedSessionId;
    private System.Threading.Timer? countdownTimer;
    private System.Threading.Timer? heartbeatTimer;
    private System.Threading.Timer? fallbackPollTimer;
    private int remainingSeconds;
    private Guid? revealedQuestionId;
    private OptionKey? revealedCorrectOption;
    private decimal? revealedCorrectNumericValue;
    private bool PreferWithoutTimerStart => string.Equals(StartMode, "without-timer", StringComparison.OrdinalIgnoreCase);
    private bool IsCurrentQuestionAnswerRevealed => snapshot?.CurrentQuestion is not null && revealedQuestionId == snapshot.CurrentQuestion.QuestionId;
    private bool isHeartbeatInFlight;
    private bool isFallbackPolling;
    private bool isFallbackPollInFlight;
    private const int FallbackPollIntervalSeconds = 3;

    private bool IsSessionRunning => snapshot?.Status == SessionStatus.Running;
    private bool IsSessionPaused => snapshot?.Status == SessionStatus.Paused;
    private bool IsSessionActive => IsSessionRunning || IsSessionPaused;
    private bool UsesQuestionTimer => snapshot?.QuestionDeadlineUtc is not null;
    private bool IsLastQuestion => snapshot is not null
        && snapshot.CurrentQuestionIndex.HasValue
        && snapshot.TotalQuestionCount > 0
        && snapshot.CurrentQuestionIndex.Value >= snapshot.TotalQuestionCount - 1;
    private string PageHeading => snapshot?.Status switch
    {
        SessionStatus.Running or SessionStatus.Paused => "Probíhající hra",
        SessionStatus.Finished => "Výsledky",
        _ => "Čekárna"
    };
    private string PauseButtonText => IsSessionPaused ? "Start hry" : "Pauza hry";
    private string AdvanceButtonText => IsLastQuestion ? "Ukončit kvíz" : "Pokračovat k další otázce";
    private const string StartButtonText = "Spustit kvíz";

    private Task StartSessionInSelectedModeAsync()
    {
        return PreferWithoutTimerStart
            ? StartSessionWithoutTimerAsync()
            : StartSessionAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (SessionId.HasValue)
        {
            sessionIdInput = SessionId.Value.ToString();
        }

        if (QuizId.HasValue)
        {
            await LoadStoredTokenAsync(QuizId.Value);
        }

        if (SessionId.HasValue && autoLoadedSessionId != SessionId.Value)
        {
            autoLoadedSessionId = SessionId.Value;
            await LoadSnapshotAsync();
            StartHeartbeatTimer();
        }
        else if (!SessionId.HasValue)
        {
            autoLoadedSessionId = null;
            StopHeartbeatTimer();
        }
    }

    private async Task LoadSnapshotAsync()
    {
        apiError = null;
        infoMessage = null;
        isLoading = true;

        var sessionId = ParseSessionId();
        if (!sessionId.HasValue)
        {
            apiError = new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Session ID není ve validním formátu GUID.");
            isLoading = false;
            return;
        }

        using var request = new HttpRequestMessage(HttpMethod.Get, $"/api/sessions/{sessionId.Value}");
        ApplyOrganizerAuth(request);

        using var response = await HttpClient.SendAsync(request);
        if (response.IsSuccessStatusCode)
        {
            var loadedSnapshot = await response.Content.ReadFromJsonAsync<OrganizerSessionSnapshotResponse>();
            if (!TryApplySnapshot(loadedSnapshot))
            {
                isLoading = false;
                return;
            }

            await ClearStoredSessionIfTerminalAsync();
            var realtimeReady = await EnsureRealtimeConnectionAsync(sessionId.Value);
            if (!realtimeReady)
            {
                StartFallbackPolling("Realtime připojení není dostupné. Běží záložní obnovování stavu.");
            }
            RestartCountdownTimer();
            UpdateActiveSessionState();
        }
        else
        {
            snapshot = null;
            countdownTimer?.Dispose();
            countdownTimer = null;
            remainingSeconds = 0;
            apiError = await ReadApiErrorAsync(response);
        }

        isLoading = false;
    }

    private async Task ShowCorrectAnswerAsync()
    {
        if (snapshot is null || snapshot.CurrentQuestion is null)
        {
            return;
        }

        apiError = null;
        infoMessage = null;

        var sessionId = ParseSessionId();
        if (!sessionId.HasValue)
        {
            apiError = new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Session ID není ve validním formátu GUID.");
            return;
        }

        isLoading = true;

        using var request = new HttpRequestMessage(HttpMethod.Get, $"/api/sessions/{sessionId.Value}/current-correct-answer");
        ApplyOrganizerAuth(request);

        using var response = await HttpClient.SendAsync(request);
        if (response.IsSuccessStatusCode)
        {
            var correctAnswer = await response.Content.ReadFromJsonAsync<CurrentQuestionCorrectAnswerResponse>();
            if (correctAnswer is null)
            {
                apiError = new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Správnou odpověď se nepodařilo načíst.");
                isLoading = false;
                return;
            }

            revealedQuestionId = correctAnswer.QuestionId;
            revealedCorrectOption = correctAnswer.CorrectOption;
            revealedCorrectNumericValue = correctAnswer.CorrectNumericValue;
        }
        else
        {
            apiError = await ReadApiErrorAsync(response);
        }

        isLoading = false;
    }

    private string BuildCorrectAnswerMessage(CurrentQuestionCorrectAnswerResponse correctAnswer)
    {
        if (correctAnswer.QuestionType == QuestionType.MultipleChoice)
        {
            var option = correctAnswer.CorrectOption;
            if (!option.HasValue)
            {
                return "Správná odpověď není dostupná.";
            }

            var optionText = snapshot?.CurrentQuestion?.Options
                .FirstOrDefault(x => x.OptionKey == option.Value)?.Text;

            return string.IsNullOrWhiteSpace(optionText)
                ? $"Správná odpověď: {option.Value}"
                : $"Správná odpověď: {option.Value} — {optionText}";
        }

        return $"Správná odpověď: {FormatDecimal(correctAnswer.CorrectNumericValue)}";
    }

    private static string FormatDecimal(decimal? value)
    {
        if (!value.HasValue)
        {
            return "-";
        }

        return value.Value.ToString("0.############################", System.Globalization.CultureInfo.CurrentCulture);
    }

    private static string ToPresenceLabel(ParticipantPresenceStatus status)
    {
        return status switch
        {
            ParticipantPresenceStatus.Connected => "online",
            ParticipantPresenceStatus.TemporarilyDisconnected => "dočasně odpojen",
            ParticipantPresenceStatus.Inactive => "neaktivní",
            _ => "neznámý"
        };
    }

    private void ResetRevealedCorrectAnswerIfQuestionChanged()
    {
        if (snapshot?.CurrentQuestion is null)
        {
            revealedQuestionId = null;
            revealedCorrectOption = null;
            revealedCorrectNumericValue = null;
            return;
        }

        if (revealedQuestionId == snapshot.CurrentQuestion.QuestionId)
        {
            return;
        }

        revealedQuestionId = null;
        revealedCorrectOption = null;
        revealedCorrectNumericValue = null;
    }

    private async Task StartSessionWithoutTimerAsync()
    {
        apiError = null;
        infoMessage = null;

        var sessionId = ParseSessionId();
        if (!sessionId.HasValue)
        {
            apiError = new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Session ID není ve validním formátu GUID.");
            return;
        }

        isLoading = true;

        using var request = new HttpRequestMessage(HttpMethod.Post, $"/api/sessions/{sessionId.Value}/start-without-timer");
        ApplyOrganizerAuth(request);

        using var response = await HttpClient.SendAsync(request);
        if (response.IsSuccessStatusCode)
        {
            var loadedSnapshot = await response.Content.ReadFromJsonAsync<OrganizerSessionSnapshotResponse>();
            if (!TryApplySnapshot(loadedSnapshot))
            {
                isLoading = false;
                return;
            }

            ResetRevealedCorrectAnswerIfQuestionChanged();
            infoMessage = "Session byla spuštěna bez časomíry.";
            RestartCountdownTimer();
            UpdateActiveSessionState();
        }
        else
        {
            apiError = await ReadApiErrorAsync(response);
        }

        isLoading = false;
    }

    private async Task AdvanceSessionAsync()
    {
        if (snapshot is null)
        {
            return;
        }

        var wasLastQuestion = IsLastQuestion;

        apiError = null;
        infoMessage = null;

        var sessionId = ParseSessionId();
        if (!sessionId.HasValue)
        {
            apiError = new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Session ID není ve validním formátu GUID.");
            return;
        }

        isLoading = true;

        using var request = new HttpRequestMessage(HttpMethod.Post, $"/api/sessions/{sessionId.Value}/advance");
        ApplyOrganizerAuth(request);

        using var response = await HttpClient.SendAsync(request);
        if (response.IsSuccessStatusCode)
        {
            var loadedSnapshot = await response.Content.ReadFromJsonAsync<OrganizerSessionSnapshotResponse>();
            if (!TryApplySnapshot(loadedSnapshot))
            {
                isLoading = false;
                return;
            }

            ResetRevealedCorrectAnswerIfQuestionChanged();
            infoMessage = wasLastQuestion
                ? "Kvíz byl ukončen."
                : "Přecházím na další otázku.";
            RestartCountdownTimer();
            UpdateActiveSessionState();
        }
        else
        {
            apiError = await ReadApiErrorAsync(response);
        }

        isLoading = false;
    }

    private async Task TogglePauseAsync()
    {
        if (snapshot is null)
        {
            return;
        }

        apiError = null;
        infoMessage = null;

        var sessionId = ParseSessionId();
        if (!sessionId.HasValue)
        {
            apiError = new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Session ID není ve validním formátu GUID.");
            return;
        }

        var wasPaused = IsSessionPaused;
        var endpoint = wasPaused
            ? $"/api/sessions/{sessionId.Value}/resume"
            : $"/api/sessions/{sessionId.Value}/pause";

        isLoading = true;

        using var request = new HttpRequestMessage(HttpMethod.Post, endpoint);
        ApplyOrganizerAuth(request);

        using var response = await HttpClient.SendAsync(request);
        if (response.IsSuccessStatusCode)
        {
            var loadedSnapshot = await response.Content.ReadFromJsonAsync<OrganizerSessionSnapshotResponse>();
            if (!TryApplySnapshot(loadedSnapshot))
            {
                isLoading = false;
                return;
            }

            ResetRevealedCorrectAnswerIfQuestionChanged();
            infoMessage = wasPaused
                ? "Session pokračuje."
                : "Session byla pozastavena.";
            RestartCountdownTimer();
            UpdateActiveSessionState();
        }
        else
        {
            apiError = await ReadApiErrorAsync(response);
        }

        isLoading = false;
    }

    private async Task<bool> EnsureRealtimeConnectionAsync(Guid sessionId)
    {
        if (hubConnection is null)
        {
            hubConnection = new HubConnectionBuilder()
                .WithUrl(new Uri(HttpClient.BaseAddress!, "/hubs/sessions"))
                .WithAutomaticReconnect(new ReconnectWithinSixtySecondsPolicy())
                .Build();

            hubConnection.On(RealtimeEventName.TeamJoined.ToWireName(), async () => await ReloadSnapshotFromRealtimeAsync(string.Empty));
            hubConnection.On(RealtimeEventName.TeamLeft.ToWireName(), async () => await ReloadSnapshotFromRealtimeAsync(string.Empty));
            hubConnection.On(RealtimeEventName.SessionStarted.ToWireName(), async () => await ReloadSnapshotFromRealtimeAsync("Hra byla spuštěna."));
            hubConnection.On(RealtimeEventName.QuestionChanged.ToWireName(), async () => await ReloadSnapshotFromRealtimeAsync(string.Empty));
            hubConnection.On(RealtimeEventName.SessionCancelled.ToWireName(), async () => await ReloadSnapshotFromRealtimeAsync("Hra byla zrušena."));
            hubConnection.On(RealtimeEventName.SessionFinished.ToWireName(), async () => await ReloadSnapshotFromRealtimeAsync("Hra byla ukončena."));
            hubConnection.On(RealtimeEventName.ResultsReady.ToWireName(), async () => await ReloadSnapshotFromRealtimeAsync("Výsledky jsou připravené."));

            hubConnection.Reconnecting += _ =>
            {
                isRealtimeConnected = false;
                StartFallbackPolling("Realtime spojení se obnovuje. Běží záložní obnovování stavu.");
                return InvokeAsync(StateHasChanged);
            };

            hubConnection.Reconnected += async _ =>
            {
                var reconnectSessionId = realtimeSessionId ?? sessionId;
                var subscribed = await SubscribeRealtimeSessionAsync(reconnectSessionId);
                if (!subscribed)
                {
                    isRealtimeConnected = false;
                    StartFallbackPolling("Realtime připojení se nepodařilo obnovit. Běží záložní obnovování stavu.");
                    return;
                }

                isRealtimeConnected = true;
                StopFallbackPolling();
                await ReloadSnapshotFromRealtimeAsync("Realtime připojení bylo obnoveno.");
            };

            hubConnection.Closed += _ =>
            {
                isRealtimeConnected = false;
                StartFallbackPolling("Realtime spojení bylo ukončeno. Běží záložní obnovování stavu.");
                return InvokeAsync(StateHasChanged);
            };
        }

        try
        {
            if (hubConnection.State == HubConnectionState.Disconnected)
            {
                await hubConnection.StartAsync();
            }

            var subscribed = await SubscribeRealtimeSessionAsync(sessionId);
            isRealtimeConnected = subscribed;
            if (subscribed)
            {
                StopFallbackPolling();
            }
            else
            {
                StartFallbackPolling("Realtime připojení není dostupné. Běží záložní obnovování stavu.");
            }

            return subscribed;
        }
        catch
        {
            isRealtimeConnected = false;
            StartFallbackPolling("Realtime připojení není dostupné. Běží záložní obnovování stavu.");
            return false;
        }
    }

    private async Task<bool> SubscribeRealtimeSessionAsync(Guid sessionId)
    {
        if (hubConnection is null)
        {
            return false;
        }

        if (realtimeSessionId.HasValue && realtimeSessionId.Value != sessionId)
        {
            await hubConnection.InvokeAsync("UnsubscribeFromSessionAsync", realtimeSessionId.Value);
        }

        var subscribed = await hubConnection.InvokeAsync<bool>("SubscribeToSessionAsync", sessionId);
        if (!subscribed)
        {
            return false;
        }

        realtimeSessionId = sessionId;
        await InvokeAsync(StateHasChanged);
        return true;
    }

    private void StartFallbackPolling(string message)
    {
        if (isFallbackPolling)
        {
            return;
        }

        isFallbackPolling = true;
        infoMessage = message;

        fallbackPollTimer = new System.Threading.Timer(_ =>
        {
            _ = InvokeAsync(RunFallbackPollAsync);
        }, null, TimeSpan.FromSeconds(FallbackPollIntervalSeconds), TimeSpan.FromSeconds(FallbackPollIntervalSeconds));
    }

    private void StopFallbackPolling()
    {
        fallbackPollTimer?.Dispose();
        fallbackPollTimer = null;
        isFallbackPolling = false;
        isFallbackPollInFlight = false;
    }

    private async Task RunFallbackPollAsync()
    {
        if (isFallbackPollInFlight)
        {
            return;
        }

        var sessionId = ParseSessionId();
        if (!sessionId.HasValue)
        {
            return;
        }

        isFallbackPollInFlight = true;
        try
        {
            await ReloadSnapshotFromRealtimeAsync(string.Empty);
            var realtimeReady = await EnsureRealtimeConnectionAsync(sessionId.Value);
            if (realtimeReady)
            {
                StopFallbackPolling();
                infoMessage = "Realtime připojení bylo obnoveno.";
            }
        }
        finally
        {
            isFallbackPollInFlight = false;
        }
    }

    private async Task ReloadSnapshotFromRealtimeAsync(string message)
    {
        await InvokeAsync(async () =>
        {
            var sessionId = ParseSessionId();
            if (!sessionId.HasValue)
            {
                return;
            }

            using var request = new HttpRequestMessage(HttpMethod.Get, $"/api/sessions/{sessionId.Value}");
            ApplyOrganizerAuth(request);

            using var response = await HttpClient.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                var loadedSnapshot = await response.Content.ReadFromJsonAsync<OrganizerSessionSnapshotResponse>();
                if (!TryApplySnapshot(loadedSnapshot))
                {
                    return;
                }

                await ClearStoredSessionIfTerminalAsync();
                ResetRevealedCorrectAnswerIfQuestionChanged();
                infoMessage = message;
                apiError = null;
                RestartCountdownTimer();
                UpdateActiveSessionState();
            }

            StateHasChanged();
        });
    }

    public async ValueTask DisposeAsync()
    {
        ActiveSessionState.Clear();

        if (hubConnection is null)
        {
            return;
        }

        if (realtimeSessionId.HasValue && hubConnection.State == HubConnectionState.Connected)
        {
            await hubConnection.InvokeAsync("UnsubscribeFromSessionAsync", realtimeSessionId.Value);
        }

        countdownTimer?.Dispose();
        countdownTimer = null;
        StopHeartbeatTimer();
        StopFallbackPolling();

        await hubConnection.DisposeAsync();
    }

    private void StartHeartbeatTimer()
    {
        StopHeartbeatTimer();

        if (!SessionId.HasValue)
        {
            return;
        }

        heartbeatTimer = new System.Threading.Timer(_ =>
        {
            _ = InvokeAsync(SendOrganizerHeartbeatAsync);
        }, null, TimeSpan.FromSeconds(10), TimeSpan.FromSeconds(10));
    }

    private void StopHeartbeatTimer()
    {
        heartbeatTimer?.Dispose();
        heartbeatTimer = null;
        isHeartbeatInFlight = false;
    }

    private async Task SendOrganizerHeartbeatAsync()
    {
        if (!SessionId.HasValue || isHeartbeatInFlight)
        {
            return;
        }

        isHeartbeatInFlight = true;
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Post, $"/api/sessions/{SessionId.Value}/heartbeat/organizer");
            ApplyOrganizerAuth(request);
            await HttpClient.SendAsync(request);
        }
        finally
        {
            isHeartbeatInFlight = false;
        }
    }

    private async Task StartSessionAsync()
    {
        apiError = null;
        infoMessage = null;

        var sessionId = ParseSessionId();
        if (!sessionId.HasValue)
        {
            apiError = new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Session ID není ve validním formátu GUID.");
            return;
        }

        isLoading = true;

        using var request = new HttpRequestMessage(HttpMethod.Post, $"/api/sessions/{sessionId.Value}/start");
        ApplyOrganizerAuth(request);

        using var response = await HttpClient.SendAsync(request);
        if (response.IsSuccessStatusCode)
        {
            var loadedSnapshot = await response.Content.ReadFromJsonAsync<OrganizerSessionSnapshotResponse>();
            if (!TryApplySnapshot(loadedSnapshot))
            {
                isLoading = false;
                return;
            }

            ResetRevealedCorrectAnswerIfQuestionChanged();
            infoMessage = "Session byla spuštěna.";
            RestartCountdownTimer();
            UpdateActiveSessionState();
        }
        else
        {
            apiError = await ReadApiErrorAsync(response);
        }

        isLoading = false;
    }

    private async Task CancelSessionAsync()
    {
        apiError = null;
        infoMessage = null;

        var sessionId = ParseSessionId();
        if (!sessionId.HasValue)
        {
            apiError = new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Session ID není ve validním formátu GUID.");
            return;
        }

        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Opravdu chcete zrušit session?");
        if (!confirmed)
        {
            infoMessage = "Zrušení session bylo stornováno.";
            return;
        }

        isLoading = true;

        using var request = new HttpRequestMessage(HttpMethod.Post, $"/api/sessions/{sessionId.Value}/cancel")
        {
            Content = JsonContent.Create(new CancelSessionRequest(true))
        };

        ApplyOrganizerAuth(request);

        using var response = await HttpClient.SendAsync(request);
        if (response.IsSuccessStatusCode)
        {
            var loadedSnapshot = await response.Content.ReadFromJsonAsync<OrganizerSessionSnapshotResponse>();
            if (!TryApplySnapshot(loadedSnapshot))
            {
                isLoading = false;
                return;
            }

            ResetRevealedCorrectAnswerIfQuestionChanged();
            infoMessage = "Session byla zrušena.";
            RestartCountdownTimer();
            UpdateActiveSessionState();
        }
        else
        {
            apiError = await ReadApiErrorAsync(response);
        }

        isLoading = false;
    }

    private async Task LoadStoredTokenAsync(Guid quizId)
    {
        var storedQuiz = await OrganizerQuizLocalStore.FindByQuizIdAsync(quizId);
        storedOrganizerToken = storedQuiz?.QuizOrganizerToken;
        storedQuizName = storedQuiz?.QuizName;
    }

    private Guid? ParseSessionId()
    {
        return Guid.TryParse(sessionIdInput, out var parsedSessionId) ? parsedSessionId : null;
    }

    private bool TryApplySnapshot(OrganizerSessionSnapshotResponse? incomingSnapshot)
    {
        if (incomingSnapshot is null)
        {
            return false;
        }

        if (snapshot is not null && incomingSnapshot.Version <= snapshot.Version)
        {
            return false;
        }

        snapshot = incomingSnapshot;
        return true;
    }

    private void ApplyOrganizerAuth(HttpRequestMessage request)
    {
        if (!string.IsNullOrWhiteSpace(storedOrganizerToken))
        {
            request.Headers.Add("X-Organizer-Token", storedOrganizerToken);
        }
    }

    private void RestartCountdownTimer()
    {
        countdownTimer?.Dispose();
        countdownTimer = null;

        UpdateRemainingSeconds();

        if (!IsSessionRunning || snapshot?.QuestionDeadlineUtc is null)
        {
            return;
        }

        countdownTimer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(() =>
            {
                UpdateRemainingSeconds();
                StateHasChanged();
            });
        }, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    private void UpdateRemainingSeconds()
    {
        if (snapshot?.QuestionDeadlineUtc is null)
        {
            remainingSeconds = 0;
            return;
        }

        var diff = snapshot.QuestionDeadlineUtc.Value - DateTimeOffset.UtcNow;
        remainingSeconds = Math.Max(0, (int)Math.Ceiling(diff.TotalSeconds));
    }

    private static async Task<ApiErrorResponse> ReadApiErrorAsync(HttpResponseMessage response)
    {
        var apiError = await response.Content.ReadFromJsonAsync<ApiErrorResponse>();
        if (apiError is not null)
        {
            return apiError;
        }

        return new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Operace selhala.");
    }

    private void UpdateActiveSessionState()
    {
        if (snapshot is not null && snapshot.Status is SessionStatus.Waiting or SessionStatus.Running or SessionStatus.Paused)
        {
            ActiveSessionState.Set("Opravdu chcete opustit hru? Aktivní kvíz bude zrušen.", async () =>
            {
                var sessionId = ParseSessionId();
                if (!sessionId.HasValue)
                {
                    return;
                }

                using var request = new HttpRequestMessage(HttpMethod.Post, $"/api/sessions/{sessionId.Value}/cancel")
                {
                    Content = JsonContent.Create(new CancelSessionRequest(true))
                };
                ApplyOrganizerAuth(request);

                using var response = await HttpClient.SendAsync(request);
            });
        }
        else
        {
            ActiveSessionState.Clear();
        }
    }

    private async Task ClearStoredSessionIfTerminalAsync()
    {
        if (snapshot is null || QuizId is null)
        {
            return;
        }

        if (snapshot.Status is SessionStatus.Finished or SessionStatus.Cancelled)
        {
            await OrganizerQuizLocalStore.SaveActiveSessionAsync(QuizId.Value, null);
        }
    }
}
