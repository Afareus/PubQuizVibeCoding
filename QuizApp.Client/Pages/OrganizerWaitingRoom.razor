@page "/organizator/session/cekarna"
@page "/organizator/session/cekarna/{SessionId:guid}"
@inject HttpClient HttpClient
@inject OrganizerQuizLocalStore OrganizerQuizLocalStore
@inject IJSRuntime JSRuntime

<PageTitle>Čekárna session</PageTitle>

<h1>Čekárna session</h1>

<p class="text-muted">Načtení stavu WAITING session a seznamu připojených týmů.</p>

@if (!string.IsNullOrWhiteSpace(infoMessage))
{
    <div class="alert alert-info" role="alert">@infoMessage</div>
}

@if (apiError is not null)
{
    <div class="alert alert-danger" role="alert">@apiError.Message</div>
}

<section class="card mb-4">
    <div class="card-body">
        <h2 class="h5">Výběr session a autentizace</h2>

        <div class="mb-3">
            <label class="form-label" for="sessionId">Session ID</label>
            <InputText id="sessionId" class="form-control" @bind-Value="sessionIdInput" />
        </div>

        <div class="mb-3">
            <label class="form-label" for="quizId">Quiz ID (pro načtení uloženého tokenu)</label>
            <InputText id="quizId" class="form-control" @bind-Value="quizIdInput" />
        </div>

        <div class="mb-3">
            <label class="form-label" for="authPassword">Mazací heslo (volitelné)</label>
            <InputText id="authPassword" class="form-control" type="password" @bind-Value="organizerPasswordForAuth" />
        </div>

        @if (!string.IsNullOrWhiteSpace(storedOrganizerToken))
        {
            <p class="mb-3">Lokální organizer token: <code>@storedOrganizerToken</code></p>
        }

        <button class="btn btn-primary" type="button" disabled="@isLoading" @onclick="LoadSnapshotAsync">@(isLoading ? "Načítám..." : "Načíst snapshot")</button>
    </div>
</section>

@if (snapshot is not null)
{
    <section class="card mb-4">
        <div class="card-body">
            <h2 class="h5 mb-3">Session detail</h2>
            <p class="mb-1"><strong>Session ID:</strong> <code>@snapshot.SessionId</code></p>
            <p class="mb-1"><strong>Quiz ID:</strong> <code>@snapshot.QuizId</code></p>
            <p class="mb-1"><strong>Join code:</strong> <code>@snapshot.JoinCode</code></p>
            <p class="mb-3"><strong>Stav:</strong> @snapshot.Status</p>

            <div class="d-flex gap-2 mb-3">
                @if (snapshot.Status == SessionStatus.Waiting)
                {
                    <button class="btn btn-success" type="button" disabled="@isLoading" @onclick="StartSessionAsync">
                        @(isLoading ? "Provádím..." : "Spustit session")
                    </button>
                }

                @if (snapshot.Status is SessionStatus.Waiting or SessionStatus.Running)
                {
                    <button class="btn btn-outline-danger" type="button" disabled="@isLoading" @onclick="CancelSessionAsync">
                        @(isLoading ? "Provádím..." : "Zrušit session")
                    </button>
                }
            </div>

            <h3 class="h6">Připojené týmy (@snapshot.Teams.Count)</h3>

            @if (snapshot.Teams.Count == 0)
            {
                <p class="mb-0">Zatím není připojen žádný tým.</p>
            }
            else
            {
                <ul class="mb-0">
                    @foreach (var team in snapshot.Teams)
                    {
                        <li><code>@team.TeamId</code> — @team.TeamName</li>
                    }
                </ul>
            }
        </div>
    </section>
}

@code {
    [Parameter]
    public Guid? SessionId { get; set; }

    [SupplyParameterFromQuery]
    public Guid? QuizId { get; set; }

    private string sessionIdInput = string.Empty;
    private string quizIdInput = string.Empty;
    private string organizerPasswordForAuth = string.Empty;
    private string? storedOrganizerToken;
    private string? infoMessage;
    private bool isLoading;

    private ApiErrorResponse? apiError;
    private OrganizerSessionSnapshotResponse? snapshot;

    protected override async Task OnParametersSetAsync()
    {
        if (SessionId.HasValue)
        {
            sessionIdInput = SessionId.Value.ToString();
        }

        if (QuizId.HasValue)
        {
            quizIdInput = QuizId.Value.ToString();
            await LoadStoredTokenAsync(QuizId.Value);
        }
    }

    private async Task LoadSnapshotAsync()
    {
        apiError = null;
        infoMessage = null;
        isLoading = true;

        var sessionId = ParseSessionId();
        if (!sessionId.HasValue)
        {
            apiError = new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Session ID není ve validním formátu GUID.");
            isLoading = false;
            return;
        }

        var quizId = ParseQuizId();
        if (quizId.HasValue)
        {
            await LoadStoredTokenAsync(quizId.Value);
        }

        using var request = new HttpRequestMessage(HttpMethod.Get, $"/api/sessions/{sessionId.Value}");
        ApplyOrganizerAuth(request);

        using var response = await HttpClient.SendAsync(request);
        if (response.IsSuccessStatusCode)
        {
            snapshot = await response.Content.ReadFromJsonAsync<OrganizerSessionSnapshotResponse>();
            infoMessage = "Snapshot session byl načten.";
        }
        else
        {
            snapshot = null;
            apiError = await ReadApiErrorAsync(response);
        }

        isLoading = false;
    }

    private async Task StartSessionAsync()
    {
        apiError = null;
        infoMessage = null;

        var sessionId = ParseSessionId();
        if (!sessionId.HasValue)
        {
            apiError = new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Session ID není ve validním formátu GUID.");
            return;
        }

        isLoading = true;

        using var request = new HttpRequestMessage(HttpMethod.Post, $"/api/sessions/{sessionId.Value}/start");
        ApplyOrganizerAuth(request);

        using var response = await HttpClient.SendAsync(request);
        if (response.IsSuccessStatusCode)
        {
            snapshot = await response.Content.ReadFromJsonAsync<OrganizerSessionSnapshotResponse>();
            infoMessage = "Session byla spuštěna.";
        }
        else
        {
            apiError = await ReadApiErrorAsync(response);
        }

        isLoading = false;
    }

    private async Task CancelSessionAsync()
    {
        apiError = null;
        infoMessage = null;

        var sessionId = ParseSessionId();
        if (!sessionId.HasValue)
        {
            apiError = new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Session ID není ve validním formátu GUID.");
            return;
        }

        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Opravdu chcete zrušit session?");
        if (!confirmed)
        {
            infoMessage = "Zrušení session bylo stornováno.";
            return;
        }

        isLoading = true;

        using var request = new HttpRequestMessage(HttpMethod.Post, $"/api/sessions/{sessionId.Value}/cancel")
        {
            Content = JsonContent.Create(new CancelSessionRequest(true))
        };

        ApplyOrganizerAuth(request);

        using var response = await HttpClient.SendAsync(request);
        if (response.IsSuccessStatusCode)
        {
            snapshot = await response.Content.ReadFromJsonAsync<OrganizerSessionSnapshotResponse>();
            infoMessage = "Session byla zrušena.";
        }
        else
        {
            apiError = await ReadApiErrorAsync(response);
        }

        isLoading = false;
    }

    private async Task LoadStoredTokenAsync(Guid quizId)
    {
        var storedQuiz = await OrganizerQuizLocalStore.FindByQuizIdAsync(quizId);
        storedOrganizerToken = storedQuiz?.QuizOrganizerToken;
    }

    private Guid? ParseSessionId()
    {
        return Guid.TryParse(sessionIdInput, out var parsedSessionId) ? parsedSessionId : null;
    }

    private Guid? ParseQuizId()
    {
        return Guid.TryParse(quizIdInput, out var parsedQuizId) ? parsedQuizId : null;
    }

    private void ApplyOrganizerAuth(HttpRequestMessage request)
    {
        if (!string.IsNullOrWhiteSpace(storedOrganizerToken))
        {
            request.Headers.Add("X-Organizer-Token", storedOrganizerToken);
        }

        if (!string.IsNullOrWhiteSpace(organizerPasswordForAuth))
        {
            request.Headers.Add("X-Quiz-Password", organizerPasswordForAuth.Trim());
        }
    }

    private static async Task<ApiErrorResponse> ReadApiErrorAsync(HttpResponseMessage response)
    {
        var apiError = await response.Content.ReadFromJsonAsync<ApiErrorResponse>();
        if (apiError is not null)
        {
            return apiError;
        }

        return new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Operace selhala.");
    }
}
