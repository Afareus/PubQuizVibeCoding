@page "/challenge/create"
@inject HttpClient HttpClient
@inject NavigationManager NavigationManager

<PageTitle>Vytvořit challenge</PageTitle>

<h1>Vytvořit challenge „Kdo mě zná nejlíp?"</h1>

<p class="text-muted">Odpovězte na 10 otázek o sobě. Přátelé budou hádat vaše odpovědi.</p>

@if (loadError is not null)
{
    <div class="alert alert-danger" role="alert">@loadError</div>
}

@if (template is null && loadError is null)
{
    <p>Načítám otázky...</p>
}

@if (template is not null && createdChallenge is null)
{
    @if (submitError is not null)
    {
        <div class="alert alert-danger" role="alert">@submitError</div>
    }

    <section class="card mb-4">
        <div class="card-body">
            <div class="mb-3">
                <label class="form-label" for="creatorName">Vaše jméno</label>
                <input id="creatorName" class="form-control" @bind="creatorName" placeholder="Zadejte vaše jméno" />
                @if (showValidation && string.IsNullOrWhiteSpace(creatorName))
                {
                    <div class="text-danger small mt-1">Zadejte vaše jméno.</div>
                }
            </div>
            <div class="mb-3">
                <label class="form-label" for="challengeTitle">Název challenge</label>
                <input id="challengeTitle" class="form-control" @bind="challengeTitle" placeholder="např. Jak dobře mě znáš?" />
                @if (showValidation && string.IsNullOrWhiteSpace(challengeTitle))
                {
                    <div class="text-danger small mt-1">Zadejte název challenge.</div>
                }
            </div>
        </div>
    </section>

    @for (int i = 0; i < template.Questions.Count; i++)
    {
        var q = template.Questions[i];
        var idx = i;
        <section class="card mb-3">
            <div class="card-body">
                <p class="fw-normal mb-2">Otázka číslo: @(idx + 1)</p>
                <p class="mb-3">@q.Text</p>
                @if (showValidation && !selectedOptions.ContainsKey(q.TemplateQuestionId))
                {
                    <div class="text-danger small mb-2">Vyberte odpověď.</div>
                }
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var opt in q.Options)
                    {
                        var optKey = opt.OptionKey;
                        var isSelected = selectedOptions.TryGetValue(q.TemplateQuestionId, out var sel) && sel == optKey;
                        <button type="button"
                                class="btn @(isSelected ? "btn-primary" : "btn-outline-primary")"
                                @onclick="() => SelectOption(idx, optKey)">
                            @opt.Text
                        </button>
                    }
                </div>
            </div>
        </section>
    }

    <button class="btn btn-success mb-4" type="button" disabled="@isSubmitting" @onclick="SubmitChallengeAsync">
        @(isSubmitting ? "Ukládám..." : "Vytvořit challenge")
    </button>
}

@if (createdChallenge is not null)
{
    var shareUrl = NavigationManager.ToAbsoluteUri($"/challenge/{createdChallenge.PublicCode}").ToString();

    <section class="card mb-4">
        <div class="card-body">
            <h2 class="h4">Challenge vytvořena! 🎉</h2>
            <p>Sdílejte odkaz s přáteli a nechte je hádat:</p>
            <div class="input-group mb-3">
                <input class="form-control" readonly value="@shareUrl" />
                <button class="btn btn-outline-secondary" type="button" @onclick="() => CopyToClipboardAsync(shareUrl)">Kopírovat</button>
            </div>
            @if (!string.IsNullOrEmpty(copiedMessage))
            {
                <div class="alert alert-success py-2">@copiedMessage</div>
            }
            <p class="mb-1"><strong>Název:</strong> @createdChallenge.Title</p>
            <p><strong>Tvůrce:</strong> @createdChallenge.CreatorName</p>
            <a class="btn btn-outline-primary mt-2" href="@($"/challenge/{createdChallenge.PublicCode}")">Otevřít challenge</a>
        </div>
    </section>
}

@code {
    private GetChallengeTemplateResponse? template;
    private string creatorName = string.Empty;
    private string challengeTitle = string.Empty;
    private Dictionary<int, string> selectedOptions = new();
    private bool isSubmitting;
    private bool showValidation;
    private string? loadError;
    private string? submitError;
    private CreateChallengeResponse? createdChallenge;
    private string copiedMessage = string.Empty;

    [Inject] private IJSRuntime JS { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            template = await HttpClient.GetFromJsonAsync<GetChallengeTemplateResponse>("/api/challenges/template");
        }
        catch (Exception ex)
        {
            loadError = $"Nepodařilo se načíst otázky: {ex.Message}";
        }
    }

    private void SelectOption(int questionIndex, string optionKey)
    {
        if (template is null) return;
        var q = template.Questions[questionIndex];
        selectedOptions[q.TemplateQuestionId] = optionKey;
    }

    private async Task SubmitChallengeAsync()
    {
        showValidation = true;
        submitError = null;

        if (string.IsNullOrWhiteSpace(creatorName) || string.IsNullOrWhiteSpace(challengeTitle))
            return;

        if (template is not null && selectedOptions.Count < template.Questions.Count)
            return;

        isSubmitting = true;

        var answers = template!.Questions
            .Select(q => new CreateChallengeAnswerDto(q.TemplateQuestionId, selectedOptions[q.TemplateQuestionId]))
            .ToList();

        var request = new CreateChallengeRequest(creatorName.Trim(), challengeTitle.Trim(), answers);

        try
        {
            using var response = await HttpClient.PostAsJsonAsync("/api/challenges/", request);
            if (response.IsSuccessStatusCode)
            {
                createdChallenge = await response.Content.ReadFromJsonAsync<CreateChallengeResponse>();
            }
            else
            {
                var error = await response.Content.ReadFromJsonAsync<ApiErrorResponse>();
                submitError = error?.Message ?? "Nepodařilo se vytvořit challenge.";
            }
        }
        catch (Exception ex)
        {
            submitError = $"Chyba při odesílání: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task CopyToClipboardAsync(string text)
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
            copiedMessage = "Odkaz byl zkopírován do schránky.";
        }
        catch
        {
            copiedMessage = "Kopírování se nepodařilo. Zkopírujte odkaz ručně.";
        }
    }
}
