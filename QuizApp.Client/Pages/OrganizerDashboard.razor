@page "/organizator"
@inject HttpClient HttpClient
@inject OrganizerQuizLocalStore OrganizerQuizLocalStore

<PageTitle>Organizátor</PageTitle>

<h1>Organizátorský panel</h1>

<p class="text-muted">Spouštějte nebo spravujte dostupné kvízy.</p>

@if (!string.IsNullOrWhiteSpace(createSuccessMessage))
{
    <div class="alert alert-success" role="alert">@createSuccessMessage</div>
}

@if (createError is not null)
{
    <div class="alert alert-danger" role="alert">@createError.Message</div>
}

@if (listError is not null)
{
    <div class="alert alert-danger" role="alert">@listError.Message</div>
}

<section class="card mb-4">
    <div class="card-body">
        <h2 class="h4 dashboard-grid-title">Dostupné kvízy</h2>

        @if (availableQuizzes.Count == 0)
        {
            <p class="mb-0">Zatím tu není žádný kvíz.</p>
        }
        else
        {
            <div class="table-responsive dashboard-grid-wrap">
                <table class="table table-sm align-middle text-start dashboard-grid-table">
                    <thead>
                        <tr class="dashboard-grid-header-row">
                            <th>Název kvízu</th>
                            <th>Datum založení</th>
                            <th>Spustitelný bez hesla</th>
                            <th></th>
                        </tr>
                        <tr class="dashboard-grid-filter-row">
                            <th>
                                <div class="dashboard-sort-filter-wrap">
                                    <button class="btn btn-sm btn-outline-secondary dashboard-sort-button" type="button" title="@GetSortButtonTitle(SortColumnName, "Název kvízu")" @onclick="() => ToggleSortByColumn(SortColumnName)">
                                        <span class="@GetSortIndicatorClass(SortColumnName)">▲</span>
                                    </button>

                                    <input id="quizSearch"
                                           class="form-control form-control-sm"
                                           placeholder="Hledat podle názvu"
                                           value="@QuizSearchTerm"
                                           @oninput="OnQuizSearchInput" />
                                </div>
                            </th>
                            <th>
                                <div class="dashboard-sort-filter-wrap">
                                    <button class="btn btn-sm btn-outline-secondary dashboard-sort-button" type="button" title="@GetSortButtonTitle(SortColumnCreatedAt, "Datum založení")" @onclick="() => ToggleSortByColumn(SortColumnCreatedAt)">
                                        <span class="@GetSortIndicatorClass(SortColumnCreatedAt)">▲</span>
                                    </button>

                                    <input id="quizCreatedAtSearch"
                                           type="date"
                                           class="form-control form-control-sm"
                                           value="@QuizCreatedAtFilter"
                                           @oninput="OnQuizCreatedAtSearchInput" />
                                </div>
                            </th>
                            <th>
                                <select id="quizRunnableFilter"
                                        class="form-select form-select-sm"
                                        value="@QuizRunnableFilter"
                                        @onchange="OnQuizRunnableFilterChanged">
                                    <option value="all">Vše</option>
                                    <option value="runnable-only">Pouze spustitelné</option>
                                </select>
                            </th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (PagedQuizzes.Count == 0)
                        {
                            <tr>
                                <td colspan="4" class="text-muted">Pro zadaný filtr nebyl nalezen žádný kvíz.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var quiz in PagedQuizzes)
                            {
                                <tr>
                                    <td>@GetQuizName(quiz)</td>
                                    <td>@GetQuizCreatedAt(quiz)</td>
                                    <td>@GetQuizRunnableStatus(quiz)</td>
                                    <td class="text-end">
                                        <a class="btn btn-sm btn-outline-primary" href="@($"/organizator/kviz/{quiz.QuizId}")">Detail</a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            @if (TotalPages > 1)
            {
                <div class="d-flex justify-content-between align-items-center gap-2">
                    <span class="text-muted small">Stránka @currentPage z @TotalPages</span>
                    <div class="btn-group" role="group" aria-label="Stránkování kvízů">
                        <button class="btn btn-sm btn-outline-secondary"
                                type="button"
                                disabled="@(currentPage <= 1)"
                                @onclick="PreviousPage">
                            Předchozí
                        </button>
                        <button class="btn btn-sm btn-outline-secondary"
                                type="button"
                                disabled="@(currentPage >= TotalPages)"
                                @onclick="NextPage">
                            Další
                        </button>
                    </div>
                </div>
            }

        }
    </div>
</section>

<section class="card mb-4">
    <div class="card-body">
        <h2 class="h5">Založit nový kvíz</h2>
        <EditForm Model="createQuizForm" OnValidSubmit="CreateQuizAsync">
            <DataAnnotationsValidator />

            <div class="mb-3">
                <label class="form-label" for="quizName">Název kvízu</label>
                <InputText id="quizName" class="form-control" @bind-Value="createQuizForm.Name" />
                <ValidationMessage For="() => createQuizForm.Name" />
            </div>

            <div class="mb-3">
                <label class="form-label" for="deletePassword">Administrátorské heslo kvízu</label>
                <InputText id="deletePassword" class="form-control" type="password" @bind-Value="createQuizForm.DeletePassword" />
                <ValidationMessage For="() => createQuizForm.DeletePassword" />
            </div>

            <button class="btn btn-primary" type="submit" disabled="@isCreatingQuiz">@CreateButtonText</button>
        </EditForm>
    </div>
</section>

@code {
    private readonly CreateQuizFormModel createQuizForm = new();
    private List<OrganizerDashboardQuizItem> availableQuizzes = [];
    private ApiErrorResponse? createError;
    private ApiErrorResponse? listError;
    private string? createSuccessMessage;
    private bool isCreatingQuiz;
    private string quizSearchTerm = string.Empty;
    private string quizCreatedAtFilter = string.Empty;
    private string quizRunnableFilter = "all";
    private const string SortColumnName = "name";
    private const string SortColumnCreatedAt = "createdAt";
    private string selectedSortColumn = SortColumnCreatedAt;
    private bool isSortAscending;
    private int currentPage = 1;
    private const int PageSize = 10;

    private string CreateButtonText => isCreatingQuiz ? "Vytvářím..." : "Vytvořit kvíz";

    private string QuizSearchTerm
    {
        get => quizSearchTerm;
        set
        {
            if (quizSearchTerm == value)
            {
                return;
            }

            quizSearchTerm = value;
            currentPage = 1;
        }
    }

    private string QuizCreatedAtFilter
    {
        get => quizCreatedAtFilter;
        set
        {
            if (quizCreatedAtFilter == value)
            {
                return;
            }

            quizCreatedAtFilter = value;
            currentPage = 1;
        }
    }

    private string QuizRunnableFilter
    {
        get => quizRunnableFilter;
        set
        {
            if (quizRunnableFilter == value)
            {
                return;
            }

            quizRunnableFilter = value;
            currentPage = 1;
        }
    }

    private IReadOnlyList<OrganizerDashboardQuizItem> PagedQuizzes
    {
        get
        {
            var filtered = GetFilteredQuizzes();
            var skip = (currentPage - 1) * PageSize;
            return filtered.Skip(skip).Take(PageSize).ToList();
        }
    }

    private int TotalPages
    {
        get
        {
            var count = GetFilteredQuizzes().Count;
            return count == 0 ? 1 : (int)Math.Ceiling(count / (double)PageSize);
        }
    }

    private void OnQuizSearchInput(ChangeEventArgs args)
    {
        QuizSearchTerm = args.Value?.ToString() ?? string.Empty;
    }

    private void OnQuizCreatedAtSearchInput(ChangeEventArgs args)
    {
        QuizCreatedAtFilter = args.Value?.ToString() ?? string.Empty;
    }

    private void OnQuizRunnableFilterChanged(ChangeEventArgs args)
    {
        var requestedValue = args.Value?.ToString() ?? "all";
        QuizRunnableFilter = string.Equals(requestedValue, "runnable-only", StringComparison.Ordinal)
            ? "runnable-only"
            : "all";
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAvailableQuizzesAsync();
    }

    private async Task CreateQuizAsync()
    {
        isCreatingQuiz = true;
        createError = null;
        createSuccessMessage = null;

        var request = new CreateQuizRequest(createQuizForm.Name.Trim(), createQuizForm.DeletePassword.Trim());
        using var response = await HttpClient.PostAsJsonAsync("/api/quizzes", request);

        if (response.IsSuccessStatusCode)
        {
            var payload = await response.Content.ReadFromJsonAsync<CreateQuizResponse>();
            if (payload is not null)
            {
                await OrganizerQuizLocalStore.UpsertAsync(
                    payload.QuizId,
                    payload.QuizOrganizerToken,
                    createQuizForm.Name.Trim(),
                    DateTimeOffset.UtcNow);
                await LoadAvailableQuizzesAsync();

                createSuccessMessage = "Kvíz byl vytvořen.";
                createQuizForm.Clear();
            }
        }
        else
        {
            createError = await ReadApiErrorAsync(response);
        }

        isCreatingQuiz = false;
    }

    private async Task LoadAvailableQuizzesAsync()
    {
        listError = null;

        var storedItems = (await OrganizerQuizLocalStore.GetAllAsync())
            .ToDictionary(x => x.QuizId, x => x, EqualityComparer<Guid>.Default);

        using var response = await HttpClient.GetAsync("/api/quizzes");
        if (!response.IsSuccessStatusCode)
        {
            availableQuizzes = [];
            listError = await ReadApiErrorAsync(response);
            NormalizeCurrentPage();
            return;
        }

        var payload = await response.Content.ReadFromJsonAsync<IReadOnlyList<QuizListItemResponse>>() ?? [];
        availableQuizzes = payload
            .Select(quiz =>
            {
                storedItems.TryGetValue(quiz.QuizId, out var storedQuiz);
                return new OrganizerDashboardQuizItem(quiz.QuizId, quiz.Name, quiz.CreatedAtUtc, quiz.IsStartAllowedForEveryone, storedQuiz?.QuizOrganizerToken);
            })
            .ToList();

        NormalizeCurrentPage();
    }

    private List<OrganizerDashboardQuizItem> GetFilteredQuizzes()
    {
        IEnumerable<OrganizerDashboardQuizItem> filtered = availableQuizzes;

        if (!string.IsNullOrWhiteSpace(QuizSearchTerm))
        {
            filtered = filtered.Where(x => GetQuizName(x).Contains(QuizSearchTerm.Trim(), StringComparison.OrdinalIgnoreCase));
        }

        if (!string.IsNullOrWhiteSpace(QuizCreatedAtFilter))
        {
            filtered = filtered.Where(x => x.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd") == QuizCreatedAtFilter);
        }

        if (string.Equals(QuizRunnableFilter, "runnable-only", StringComparison.Ordinal))
        {
            filtered = filtered.Where(x => x.IsStartAllowedForEveryone);
        }

        filtered = ApplySelectedSorting(filtered);

        return filtered.ToList();
    }

    private IEnumerable<OrganizerDashboardQuizItem> ApplySelectedSorting(IEnumerable<OrganizerDashboardQuizItem> quizzes)
    {
        return selectedSortColumn switch
        {
            SortColumnName => isSortAscending
                ? quizzes.OrderBy(x => GetQuizName(x), StringComparer.CurrentCultureIgnoreCase).ThenByDescending(x => x.CreatedAtUtc)
                : quizzes.OrderByDescending(x => GetQuizName(x), StringComparer.CurrentCultureIgnoreCase).ThenByDescending(x => x.CreatedAtUtc),
            _ => isSortAscending
                ? quizzes.OrderBy(x => x.CreatedAtUtc).ThenBy(x => GetQuizName(x), StringComparer.CurrentCultureIgnoreCase)
                : quizzes.OrderByDescending(x => x.CreatedAtUtc).ThenBy(x => GetQuizName(x), StringComparer.CurrentCultureIgnoreCase)
        };
    }

    private void ToggleSortByColumn(string column)
    {
        if (string.Equals(selectedSortColumn, column, StringComparison.Ordinal))
        {
            isSortAscending = !isSortAscending;
        }
        else
        {
            selectedSortColumn = column;
            isSortAscending = true;
        }

        currentPage = 1;
    }

    private string GetSortIndicatorClass(string column)
    {
        if (!string.Equals(selectedSortColumn, column, StringComparison.Ordinal))
        {
            return "dashboard-sort-indicator is-inactive";
        }

        return isSortAscending
            ? "dashboard-sort-indicator is-ascending"
            : "dashboard-sort-indicator is-descending";
    }

    private string GetSortButtonTitle(string columnKey, string columnLabel)
    {
        var isCurrentColumn = string.Equals(selectedSortColumn, columnKey, StringComparison.Ordinal);
        var nextDirectionLabel = !isCurrentColumn || !isSortAscending ? "vzestupně" : "sestupně";
        return $"Seřadit podle sloupce {columnLabel} {nextDirectionLabel}.";
    }

    private void PreviousPage()
    {
        if (currentPage <= 1)
        {
            return;
        }

        currentPage--;
    }

    private void NextPage()
    {
        if (currentPage >= TotalPages)
        {
            return;
        }

        currentPage++;
    }

    private void NormalizeCurrentPage()
    {
        if (currentPage < 1)
        {
            currentPage = 1;
            return;
        }

        var maxPage = TotalPages;
        if (currentPage > maxPage)
        {
            currentPage = maxPage;
        }
    }

    private static string GetQuizName(OrganizerDashboardQuizItem quiz)
    {
        return string.IsNullOrWhiteSpace(quiz.Name) ? "(neznámý název)" : quiz.Name;
    }

    private static string GetQuizCreatedAt(OrganizerDashboardQuizItem quiz)
    {
        return quiz.CreatedAtUtc.ToLocalTime().ToString("dd.MM.yyyy");
    }

    private static string GetQuizRunnableStatus(OrganizerDashboardQuizItem quiz)
    {
        return quiz.IsStartAllowedForEveryone ? "Ano" : "Ne";
    }

    private static async Task<ApiErrorResponse> ReadApiErrorAsync(HttpResponseMessage response)
    {
        if (response.StatusCode is System.Net.HttpStatusCode.TooManyRequests)
        {
            return new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Příliš mnoho požadavků. Počkejte chvíli a zkuste to znovu.");
        }

        var apiError = await response.Content.ReadFromJsonAsync<ApiErrorResponse>();
        if (apiError is not null)
        {
            return apiError;
        }

        return new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Operace selhala.");
    }

    private sealed class CreateQuizFormModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Název kvízu je povinný.")]
        public string Name { get; set; } = string.Empty;

        [QuizApp.Shared.Validation.QuizPassword]
        public string DeletePassword { get; set; } = string.Empty;

        public void Clear()
        {
            Name = string.Empty;
            DeletePassword = string.Empty;
        }
    }

    private sealed record OrganizerDashboardQuizItem(
        Guid QuizId,
        string Name,
        DateTimeOffset CreatedAtUtc,
        bool IsStartAllowedForEveryone,
        string? OrganizerToken);
}




