@page "/organizator/kviz"
@page "/organizator/kviz/{QuizId:guid}"
@inject HttpClient HttpClient
@inject OrganizerQuizLocalStore OrganizerQuizLocalStore
@inject NavigationManager NavigationManager

<PageTitle>Detail kvízu</PageTitle>

<h1>Detail kvízu</h1>

<p class="text-muted">Správa vybraného kvízu.</p>

@if (!string.IsNullOrWhiteSpace(infoMessage))
{
    <div class="alert alert-info" role="alert">@infoMessage</div>
}

@if (apiError is not null)
{
    <div class="alert alert-danger" role="alert">@apiError.Message</div>
}

<section class="card mb-4">
    <div class="card-body">
        <h2 class="h5 mb-3">@(quizDetail?.Name ?? "(Načítám název kvízu...)")</h2>
        <button class="btn btn-success" type="button" disabled="@(isCreatingSession || isLoadingDetail || quizDetail is null)" @onclick="StartQuizAsync">@(isCreatingSession ? "Spouštím..." : "Spustit kvíz")</button>
    </div>
</section>

<section class="card mb-4">
    <div class="card-body">
        <h2 class="h5">Import CSV</h2>

        <InputFile OnChange="ReadCsvFileAsync" accept=".csv,text/csv" />

        @if (!string.IsNullOrWhiteSpace(selectedFileName))
        {
            <p class="mt-2 mb-2">Vybraný soubor: <strong>@selectedFileName</strong></p>
        }

        <button class="btn btn-outline-primary" type="button" disabled="@isImporting" @onclick="ImportCsvAsync">@(isImporting ? "Importuji..." : "Nahrát CSV")</button>

        @if (importResult is not null)
        {
            <div class="mt-3">
                <p class="mb-2">Importováno otázek: <strong>@importResult.ImportedQuestionsCount</strong></p>

                @if (importResult.ValidationIssues.Count > 0)
                {
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Řádek</th>
                                    <th>Sloupec</th>
                                    <th>Chyba</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var issue in importResult.ValidationIssues)
                                {
                                    <tr>
                                        <td>@issue.Row</td>
                                        <td>@issue.Column</td>
                                        <td>@issue.Message</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        }
    </div>
</section>

<section class="card mb-4">
    <div class="card-body">
        <h2 class="h5">Otázky kvízu</h2>
        <p class="text-muted">Otázky i správné odpovědi se zobrazí až po zadání Administrátorského hesla kvízu.</p>

        @if (questionApiError is not null)
        {
            <div class="alert alert-danger" role="alert">@questionApiError.Message</div>
        }

        @if (!string.IsNullOrWhiteSpace(questionInfoMessage))
        {
            <div class="alert alert-info" role="alert">@questionInfoMessage</div>
        }

        @if (!hasLoadedQuestions)
        {
            <div class="mb-3">
                <label class="form-label" for="questionsPassword">Administrátorské heslo kvízu</label>
                <InputText id="questionsPassword" class="form-control" type="password" @bind-Value="questionsPassword" />
            </div>

            <button class="btn btn-outline-primary mb-3" type="button" disabled="@isLoadingQuestions" @onclick="LoadQuestionsAsync">@(isLoadingQuestions ? "Načítám otázky..." : "Zobrazit otázky")</button>
        }

        @if (hasLoadedQuestions)
        {
            @if (revealedQuestions.Count == 0)
            {
                <p class="mb-0">Kvíz zatím neobsahuje žádné otázky.</p>
            }
            else
            {
                <div class="d-flex flex-column gap-3">
                    @foreach (var question in revealedQuestions.OrderBy(x => x.OrderIndex))
                    {
                        <article class="border rounded p-3">
                            <h3 class="h6 mb-1">@(question.OrderIndex + 1). @question.Text</h3>
                            <p class="mb-2 text-muted">Čas na odpověď: <strong>@question.TimeLimitSec s</strong></p>

                            <ul class="list-group list-group-flush">
                                @foreach (var option in question.Options.OrderBy(x => x.OptionKey))
                                {
                                    var isCorrectOption = option.OptionKey == question.CorrectOption;
                                    <li class="list-group-item d-flex justify-content-between align-items-center px-0 @(isCorrectOption ? "text-success fw-semibold" : string.Empty)">
                                        <span>@option.OptionKey) @option.Text</span>

                                        @if (isCorrectOption)
                                        {
                                            <span class="badge text-bg-success">Správná</span>
                                        }
                                    </li>
                                }
                            </ul>
                        </article>
                    }
                </div>
            }
        }
    </div>
</section>

<section class="card border-danger mb-4">
    <div class="card-body">
        <h2 class="h5 text-danger">Smazání kvízu</h2>
        <p>Zadání správného Administrátorkého hesla kvízu je povinné.</p>

        <div class="mb-3">
            <label class="form-label" for="deletePassword">Administrátorké heslo kvízu</label>
            <InputText id="deletePassword" class="form-control" type="password" @bind-Value="deletePassword" />
        </div>

        <button class="btn btn-danger" type="button" disabled="@isDeleting" @onclick="DeleteQuizAsync">@(isDeleting ? "Mažu..." : "Smazat kvíz")</button>
    </div>
</section>

@code {
    [Parameter]
    public Guid? QuizId { get; set; }

    private string deletePassword = string.Empty;
    private string questionsPassword = string.Empty;
    private string? storedOrganizerToken;
    private string? selectedFileName;
    private string? csvContent;
    private string? infoMessage;
    private string? questionInfoMessage;
    private bool isLoadingDetail;
    private bool isImporting;
    private bool isCreatingSession;
    private bool isDeleting;
    private bool isLoadingQuestions;
    private bool hasLoadedQuestions;

    private ApiErrorResponse? apiError;
    private ApiErrorResponse? questionApiError;
    private QuizDetailResponse? quizDetail;
    private ImportQuizCsvResponse? importResult;
    private IReadOnlyList<QuizDetailQuestionDto> revealedQuestions = [];

    protected override async Task OnParametersSetAsync()
    {
        if (QuizId.HasValue)
        {
            ResetRevealedQuestionsState();
            await LoadStoredTokenAsync(QuizId.Value);
            await LoadDetailAsync(false);
            return;
        }

        quizDetail = null;
        apiError = new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Chybí ID kvízu v URL.");
    }

    private async Task LoadDetailAsync(bool showSuccessMessage)
    {
        apiError = null;
        infoMessage = null;
        isLoadingDetail = true;

        var quizId = GetQuizId();
        if (!quizId.HasValue)
        {
            apiError = new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Quiz ID není ve validním formátu GUID.");
            isLoadingDetail = false;
            return;
        }

        await LoadStoredTokenAsync(quizId.Value);

        using var request = new HttpRequestMessage(HttpMethod.Get, $"/api/quizzes/{quizId.Value}");
        ApplyOrganizerAuth(request);

        using var response = await HttpClient.SendAsync(request);
        if (response.IsSuccessStatusCode)
        {
            var payload = await response.Content.ReadFromJsonAsync<QuizDetailResponse>();
            quizDetail = payload is null
                ? null
                : payload with { Questions = [] };

            if (showSuccessMessage)
            {
                infoMessage = "Detail kvízu byl načten.";
            }
        }
        else
        {
            quizDetail = null;
            apiError = await ReadApiErrorAsync(response);
        }

        isLoadingDetail = false;
    }

    private async Task ReadCsvFileAsync(InputFileChangeEventArgs args)
    {
        var file = args.File;
        if (file is null)
        {
            return;
        }

        await using var stream = file.OpenReadStream(1024 * 1024);
        using var reader = new StreamReader(stream);

        csvContent = await reader.ReadToEndAsync();
        selectedFileName = file.Name;
        infoMessage = "CSV soubor je načtený a připravený k importu.";
    }

    private async Task ImportCsvAsync()
    {
        apiError = null;
        infoMessage = null;
        isImporting = true;

        var quizId = GetQuizId();
        if (!quizId.HasValue)
        {
            apiError = new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Quiz ID není ve validním formátu GUID.");
            isImporting = false;
            return;
        }

        if (string.IsNullOrWhiteSpace(csvContent))
        {
            apiError = new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Nejprve vyberte CSV soubor.");
            isImporting = false;
            return;
        }

        await LoadStoredTokenAsync(quizId.Value);

        using var request = new HttpRequestMessage(HttpMethod.Post, $"/api/quizzes/{quizId.Value}/import-csv");
        request.Content = JsonContent.Create(new ImportQuizCsvRequest(quizId.Value, csvContent));
        ApplyOrganizerAuth(request);

        using var response = await HttpClient.SendAsync(request);
        if (response.IsSuccessStatusCode)
        {
            importResult = await response.Content.ReadFromJsonAsync<ImportQuizCsvResponse>();
            infoMessage = "Import CSV byl dokončen.";
            await LoadDetailAsync(false);
        }
        else
        {
            importResult = null;
            apiError = await ReadApiErrorAsync(response);
        }

        isImporting = false;
    }

    private async Task LoadQuestionsAsync()
    {
        questionApiError = null;
        questionInfoMessage = null;
        isLoadingQuestions = true;

        var quizId = GetQuizId();
        if (!quizId.HasValue)
        {
            questionApiError = new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Quiz ID není ve validním formátu GUID.");
            isLoadingQuestions = false;
            return;
        }

        if (string.IsNullOrWhiteSpace(questionsPassword))
        {
            questionApiError = new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Pro zobrazení otázek zadejte Administrátorské heslo kvízu.");
            isLoadingQuestions = false;
            return;
        }

        using var request = new HttpRequestMessage(HttpMethod.Get, $"/api/quizzes/{quizId.Value}");
        request.Headers.Add("X-Quiz-Password", questionsPassword.Trim());

        using var response = await HttpClient.SendAsync(request);
        if (response.IsSuccessStatusCode)
        {
            var detail = await response.Content.ReadFromJsonAsync<QuizDetailResponse>();
            revealedQuestions = detail?.Questions ?? [];
            hasLoadedQuestions = true;
            questionInfoMessage = $"Načteno otázek: {revealedQuestions.Count}.";
        }
        else
        {
            revealedQuestions = [];
            hasLoadedQuestions = false;
            questionApiError = await ReadApiErrorAsync(response);
        }

        isLoadingQuestions = false;
    }

    private async Task StartQuizAsync()
    {
        apiError = null;
        infoMessage = null;
        isCreatingSession = true;

        var quizId = GetQuizId();
        if (!quizId.HasValue)
        {
            apiError = new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Quiz ID není ve validním formátu GUID.");
            isCreatingSession = false;
            return;
        }

        await LoadStoredTokenAsync(quizId.Value);

        using var request = new HttpRequestMessage(HttpMethod.Post, $"/api/quizzes/{quizId.Value}/sessions");
        ApplyOrganizerAuth(request);

        using var response = await HttpClient.SendAsync(request);
        if (response.IsSuccessStatusCode)
        {
            var createdSession = await response.Content.ReadFromJsonAsync<CreateSessionResponse>();
            if (createdSession is null)
            {
                apiError = new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Nepodařilo se načíst založenou session.");
                isCreatingSession = false;
                return;
            }

            NavigationManager.NavigateTo($"/organizator/session/cekarna/{createdSession.SessionId}?quizId={quizId.Value}");
            return;
        }
        else
        {
            apiError = await ReadApiErrorAsync(response);
        }

        isCreatingSession = false;
    }

    private async Task DeleteQuizAsync()
    {
        apiError = null;
        infoMessage = null;
        isDeleting = true;

        var quizId = GetQuizId();
        if (!quizId.HasValue)
        {
            apiError = new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Quiz ID není ve validním formátu GUID.");
            isDeleting = false;
            return;
        }

        if (string.IsNullOrWhiteSpace(deletePassword))
        {
            apiError = new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Pro smazání je nutné zadat Administrátorké heslo kvízu.");
            isDeleting = false;
            return;
        }

        await LoadStoredTokenAsync(quizId.Value);

        using var request = new HttpRequestMessage(HttpMethod.Delete, $"/api/quizzes/{quizId.Value}");
        request.Headers.Add("X-Quiz-Password", deletePassword.Trim());

        if (!string.IsNullOrWhiteSpace(storedOrganizerToken))
        {
            request.Headers.Add("X-Organizer-Token", storedOrganizerToken);
        }

        using var response = await HttpClient.SendAsync(request);
        if (response.IsSuccessStatusCode)
        {
            await OrganizerQuizLocalStore.RemoveAsync(quizId.Value);
            NavigationManager.NavigateTo("/organizator");
            return;
        }

        apiError = await ReadApiErrorAsync(response);
        isDeleting = false;
    }

    private async Task LoadStoredTokenAsync(Guid quizId)
    {
        var storedQuiz = await OrganizerQuizLocalStore.FindByQuizIdAsync(quizId);
        storedOrganizerToken = storedQuiz?.QuizOrganizerToken;
    }

    private Guid? GetQuizId() => QuizId;

    private void ResetRevealedQuestionsState()
    {
        questionsPassword = string.Empty;
        questionInfoMessage = null;
        questionApiError = null;
        hasLoadedQuestions = false;
        revealedQuestions = [];
    }

    private void ApplyOrganizerAuth(HttpRequestMessage request)
    {
        if (!string.IsNullOrWhiteSpace(storedOrganizerToken))
        {
            request.Headers.Add("X-Organizer-Token", storedOrganizerToken);
        }
    }

    private static async Task<ApiErrorResponse> ReadApiErrorAsync(HttpResponseMessage response)
    {
        var apiError = await response.Content.ReadFromJsonAsync<ApiErrorResponse>();
        if (apiError is not null)
        {
            return apiError;
        }

        return new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Operace selhala.");
    }
}
