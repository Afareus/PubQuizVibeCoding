@page "/organizator/kviz"
@page "/organizator/kviz/{QuizId:guid}"
@inject HttpClient HttpClient
@inject OrganizerQuizLocalStore OrganizerQuizLocalStore
@inject NavigationManager NavigationManager

<PageTitle>Detail kvízu</PageTitle>

<h1>Detail kvízu</h1>

<p class="text-muted">Správa vybraného kvízu.</p>

@if (!string.IsNullOrWhiteSpace(infoMessage))
{
    <div class="alert alert-info" role="alert">@infoMessage</div>
}

@if (apiError is not null)
{
    <div class="alert alert-danger" role="alert">@apiError.Message</div>
}

<section class="card mb-4">
    <div class="card-body">
        <h2 class="h5 mb-3">@(quizDetail?.Name ?? "(Načítám název kvízu...)")</h2>

        <div class="mb-3">
            <label class="form-label" for="joinCode">Join kód pro hráče</label>
            <InputText id="joinCode" class="form-control" @bind-Value="joinCode" />
            <div class="form-text">Join kód musí mít alespoň 4 znaky.</div>
        </div>

        <div class="form-check mb-3">
            <InputCheckbox id="quizWithTimer" class="form-check-input" @bind-Value="isQuizTimerEnabled" />
            <label class="form-check-label" for="quizWithTimer">Kvíz s časomírou</label>
        </div>

        <button class="btn btn-success" type="button" disabled="@(isCreatingSession || isLoadingDetail || quizDetail is null)" @onclick="StartQuizAsync">@(isCreatingSession ? "Spouštím..." : "Spustit kvíz")</button>
    </div>
</section>

<section class="card mb-4">
    <div class="card-body">
        <h2 class="h5">Otázky kvízu</h2>
        @if ((quizDetail?.QuestionCount ?? 0) > 0)
        {
            <p class="text-muted">Otázky i správné odpovědi se zobrazí až po zadání Administrátorského hesla kvízu.</p>
        }

        @if (questionApiError is not null)
        {
            <div class="alert alert-danger" role="alert">@questionApiError.Message</div>
        }

        @if (!string.IsNullOrWhiteSpace(questionInfoMessage))
        {
            <div class="alert alert-info" role="alert">@questionInfoMessage</div>
        }

        @if (!hasLoadedQuestions && (quizDetail?.QuestionCount ?? 0) > 0 && !allowManualAddWithoutPassword)
        {
            <div class="mb-3">
                <label class="form-label" for="questionsPassword">Administrátorské heslo kvízu</label>
                <InputText id="questionsPassword" class="form-control" type="password" @bind-Value="questionsPassword" />
            </div>

            <button class="btn btn-outline-primary mb-3" type="button" disabled="@isLoadingQuestions" @onclick="LoadQuestionsAsync">@(isLoadingQuestions ? "Načítám otázky..." : "Zobrazit otázky")</button>
        }

        @if (hasLoadedQuestions || (quizDetail?.QuestionCount ?? 0) == 0 || allowManualAddWithoutPassword)
        {
            <div class="d-flex flex-column gap-3 mb-3">
                @foreach (var question in questionEditors.OrderBy(x => x.Order))
                {
                    var canMoveUp = question.Order > 1;
                    var canMoveDown = question.Order < questionEditors.Count;

                    <article class="border rounded p-3 quiz-question-item">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <h3 class="h5 fw-normal mb-0">Otázka číslo: <span class="quiz-order-number">@question.Order</span></h3>
                            <div class="d-flex gap-1">
                                <button class="btn btn-sm btn-outline-secondary quiz-order-move-button" type="button" disabled="@(!canMoveUp || isSavingQuestion || isLoadingQuestions)" @onclick="() => MoveQuestionUpAsync(question)">↑</button>
                                <button class="btn btn-sm btn-outline-secondary quiz-order-move-button" type="button" disabled="@(!canMoveDown || isSavingQuestion || isLoadingQuestions)" @onclick="() => MoveQuestionDownAsync(question)">↓</button>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label mb-1">Text otázky</label>
                            <InputText class="form-control quiz-question-live-text" @bind-Value="question.Text" placeholder="Doplňte text otázky" />
                            @if (TryGetQuestionValidationMessage(question, nameof(QuestionEditorModel.Text), out var textError))
                            {
                                <div class="text-danger small mt-1">@textError</div>
                            }
                        </div>

                        @if (question.QuestionType == QuestionType.MultipleChoice)
                        {
                            <div class="d-grid gap-2 mb-3">
                                <div class="quiz-option-live-edit">
                                    <span class="quiz-option-live-key">A</span>
                                    <InputText class="form-control quiz-option-live-input" @bind-Value="question.OptionA" placeholder="Odpověď A" />
                                </div>
                                @if (TryGetQuestionValidationMessage(question, nameof(QuestionEditorModel.OptionA), out var optionAError))
                                {
                                    <div class="text-danger small mt-1">@optionAError</div>
                                }

                                <div class="quiz-option-live-edit">
                                    <span class="quiz-option-live-key">B</span>
                                    <InputText class="form-control quiz-option-live-input" @bind-Value="question.OptionB" placeholder="Odpověď B" />
                                </div>
                                @if (TryGetQuestionValidationMessage(question, nameof(QuestionEditorModel.OptionB), out var optionBError))
                                {
                                    <div class="text-danger small mt-1">@optionBError</div>
                                }

                                <div class="quiz-option-live-edit">
                                    <span class="quiz-option-live-key">C</span>
                                    <InputText class="form-control quiz-option-live-input" @bind-Value="question.OptionC" placeholder="Odpověď C" />
                                </div>
                                @if (TryGetQuestionValidationMessage(question, nameof(QuestionEditorModel.OptionC), out var optionCError))
                                {
                                    <div class="text-danger small mt-1">@optionCError</div>
                                }

                                <div class="quiz-option-live-edit">
                                    <span class="quiz-option-live-key">D</span>
                                    <InputText class="form-control quiz-option-live-input" @bind-Value="question.OptionD" placeholder="Odpověď D" />
                                </div>
                                @if (TryGetQuestionValidationMessage(question, nameof(QuestionEditorModel.OptionD), out var optionDError))
                                {
                                    <div class="text-danger small mt-1">@optionDError</div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="mb-3">
                                <p class="mb-2 text-muted">Bod získá nejbližší odpověď.</p>
                                <label class="form-label">Správná odpověď:</label>
                                <InputNumber class="form-control" @bind-Value="question.CorrectNumericValue" />
                                @if (TryGetQuestionValidationMessage(question, nameof(QuestionEditorModel.CorrectNumericValue), out var correctNumericError))
                                {
                                    <div class="text-danger small mt-1">@correctNumericError</div>
                                }
                            </div>
                        }

                        <div class="row g-2 align-items-end">
                            <div class="col-12 col-md-4">
                                <label class="form-label">Typ otázky</label>
                                <InputSelect class="form-select" @bind-Value="question.QuestionType" @bind-Value:after="() => OnQuestionTypeChanged(question)">
                                    <option value="@QuestionType.MultipleChoice">Výběr A-D</option>
                                    <option value="@QuestionType.NumericClosest">Číselný tip</option>
                                </InputSelect>
                            </div>
                            <div class="col-12 col-md-4">
                                <label class="form-label">Časový limit (sekundy)</label>
                                <InputNumber class="form-control" @bind-Value="question.TimeLimitSec" />
                                @if (TryGetQuestionValidationMessage(question, nameof(QuestionEditorModel.TimeLimitSec), out var timeLimitError))
                                {
                                    <div class="text-danger small mt-1">@timeLimitError</div>
                                }
                            </div>
                            @if (question.QuestionType == QuestionType.MultipleChoice)
                            {
                                <div class="col-12 col-md-4">
                                    <label class="form-label">Správná odpověď</label>
                                    <InputSelect class="form-select" @bind-Value="question.CorrectOption">
                                        <option value="">Vyberte správnou odpověď</option>
                                        <option value="@OptionKey.A">A</option>
                                        <option value="@OptionKey.B">B</option>
                                        <option value="@OptionKey.C">C</option>
                                        <option value="@OptionKey.D">D</option>
                                    </InputSelect>
                                    @if (TryGetQuestionValidationMessage(question, nameof(QuestionEditorModel.CorrectOption), out var correctOptionError))
                                    {
                                        <div class="text-danger small mt-1">@correctOptionError</div>
                                    }
                                </div>
                            }
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-3">
                            <button class="btn btn-outline-danger" type="button" disabled="@(isSavingQuestion || isLoadingQuestions)" @onclick="() => DeleteQuestionAsync(question)">@(isSavingQuestionId == question.ClientId && isDeletingQuestionAction ? "Mažu..." : "Smazat")</button>
                            <button class="btn btn-outline-primary" type="button" disabled="@(isSavingQuestion || isLoadingQuestions)" @onclick="() => SaveQuestionAsync(question)">@(isSavingQuestionId == question.ClientId ? "Ukládám..." : "Uložit")</button>
                        </div>
                    </article>
                }
            </div>

            <button class="btn btn-outline-primary quiz-add-question-button" type="button" disabled="@(isSavingQuestion || isLoadingQuestions)" @onclick="AddEmptyQuestion">+</button>
        }
    </div>
</section>

<section class="card mb-4">
    <div class="card-body text-start">
        <h2 class="h5">Import otázek CSV</h2>
        <p class="mb-2">
            <a class="link-primary" href="@($"templates/quiz-question-import-template.csv?v={CsvTemplateVersion}")" download>Stáhnout CSV předpis (šablonu)</a>
        </p>
        <p class="form-text mt-0">CSV import používá oddělovač <strong>středník (;)</strong>.</p>

        <InputFile OnChange="ReadCsvFileAsync" accept=".csv,text/csv" />

        @if (!string.IsNullOrWhiteSpace(selectedFileName))
        {
            <p class="mt-2 mb-2">Vybraný soubor: <strong>@selectedFileName</strong></p>
        }

        <button class="btn btn-outline-primary" type="button" disabled="@isImporting" @onclick="ImportCsvAsync">@(isImporting ? "Importuji..." : "Nahrát CSV")</button>

        @if (importResult is not null)
        {
            <div class="mt-3">
                <p class="mb-2">Importováno otázek: <strong>@importResult.ImportedQuestionsCount</strong></p>

                @if (importResult.ValidationIssues.Count > 0)
                {
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Řádek</th>
                                    <th>Sloupec</th>
                                    <th>Chyba</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var issue in importResult.ValidationIssues)
                                {
                                    <tr>
                                        <td>@issue.Row</td>
                                        <td>@issue.Column</td>
                                        <td>@issue.Message</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        }
    </div>
</section>

<section class="card border-danger mb-4">
    <div class="card-body">
        <h2 class="h5 text-danger">Smazání kvízu</h2>
        <p>Zadání správného Administrátorkého hesla kvízu je povinné.</p>

        <div class="mb-3">
            <label class="form-label" for="deletePassword">Administrátorké heslo kvízu</label>
            <InputText id="deletePassword" class="form-control" type="password" @bind-Value="deletePassword" />
        </div>

        <button class="btn btn-danger" type="button" disabled="@isDeleting" @onclick="DeleteQuizAsync">@(isDeleting ? "Mažu..." : "Smazat kvíz")</button>
    </div>
</section>

@code {
    [Parameter]
    public Guid? QuizId { get; set; }

    private const string CsvTemplateVersion = "20260402";

    private string deletePassword = string.Empty;
    private string joinCode = string.Empty;
    private string questionsPassword = string.Empty;
    private string? storedOrganizerToken;
    private string? selectedFileName;
    private string? csvContent;
    private string? infoMessage;
    private string? questionInfoMessage;
    private bool isLoadingDetail;
    private bool isImporting;
    private bool isCreatingSession;
    private bool isDeleting;
    private bool isLoadingQuestions;
    private bool isSavingQuestion;
    private bool isDeletingQuestionAction;
    private bool isQuizTimerEnabled;
    private bool hasLoadedQuestions;
    private bool allowManualAddWithoutPassword;
    private Guid? isSavingQuestionId;

    private ApiErrorResponse? apiError;
    private ApiErrorResponse? questionApiError;
    private QuizDetailResponse? quizDetail;
    private ImportQuizCsvResponse? importResult;
    private IReadOnlyList<QuizDetailQuestionDto> revealedQuestions = [];
    private List<QuestionEditorModel> questionEditors = [];

    protected override async Task OnParametersSetAsync()
    {
        if (QuizId.HasValue)
        {
            ResetRevealedQuestionsState();
            await LoadStoredTokenAsync(QuizId.Value);
            await LoadDetailAsync(false);
            return;
        }

        quizDetail = null;
        apiError = new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Chybí ID kvízu v URL.");
    }

    private async Task LoadDetailAsync(bool showSuccessMessage)
    {
        apiError = null;
        infoMessage = null;
        isLoadingDetail = true;

        var quizId = GetQuizId();
        if (!quizId.HasValue)
        {
            apiError = new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Quiz ID není ve validním formátu GUID.");
            isLoadingDetail = false;
            return;
        }

        await LoadStoredTokenAsync(quizId.Value);

        using var request = new HttpRequestMessage(HttpMethod.Get, $"/api/quizzes/{quizId.Value}");
        ApplyOrganizerAuth(request);

        using var response = await HttpClient.SendAsync(request);
        if (response.IsSuccessStatusCode)
        {
            var payload = await response.Content.ReadFromJsonAsync<QuizDetailResponse>();
            quizDetail = payload is null
                ? null
                : payload with { Questions = [] };

            if (showSuccessMessage)
            {
                infoMessage = "Detail kvízu byl načten.";
            }
        }
        else
        {
            quizDetail = null;
            apiError = await ReadApiErrorAsync(response);
        }

        isLoadingDetail = false;
    }

    private async Task ReadCsvFileAsync(InputFileChangeEventArgs args)
    {
        var file = args.File;
        if (file is null)
        {
            return;
        }

        await using var stream = file.OpenReadStream(1024 * 1024);
        using var memoryStream = new MemoryStream();
        await stream.CopyToAsync(memoryStream);

        csvContent = DecodeCsvContent(memoryStream.ToArray());
        selectedFileName = file.Name;
        infoMessage = "CSV soubor je načtený a připravený k importu.";
    }

    private async Task ImportCsvAsync()
    {
        apiError = null;
        infoMessage = null;
        isImporting = true;

        var quizId = GetQuizId();
        if (!quizId.HasValue)
        {
            apiError = new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Quiz ID není ve validním formátu GUID.");
            isImporting = false;
            return;
        }

        if (string.IsNullOrWhiteSpace(csvContent))
        {
            apiError = new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Nejprve vyberte CSV soubor.");
            isImporting = false;
            return;
        }

        await LoadStoredTokenAsync(quizId.Value);

        using var request = new HttpRequestMessage(HttpMethod.Post, $"/api/quizzes/{quizId.Value}/import-csv");
        request.Content = JsonContent.Create(new ImportQuizCsvRequest(quizId.Value, csvContent));
        ApplyOrganizerAuth(request);

        using var response = await HttpClient.SendAsync(request);
        if (response.IsSuccessStatusCode)
        {
            importResult = await response.Content.ReadFromJsonAsync<ImportQuizCsvResponse>();
            infoMessage = "Import CSV byl dokončen.";
            await LoadDetailAsync(false);

            if ((importResult?.ImportedQuestionsCount ?? 0) > 0)
            {
                await LoadQuestionsAsync();
            }
        }
        else
        {
            importResult = null;
            apiError = await ReadApiErrorAsync(response);
        }

        isImporting = false;
    }

    private async Task LoadQuestionsAsync()
    {
        questionApiError = null;
        questionInfoMessage = null;
        isLoadingQuestions = true;

        var quizId = GetQuizId();
        if (!quizId.HasValue)
        {
            questionApiError = new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Quiz ID není ve validním formátu GUID.");
            isLoadingQuestions = false;
            return;
        }

        if (string.IsNullOrWhiteSpace(questionsPassword))
        {
            questionApiError = new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Pro zobrazení otázek zadejte Administrátorské heslo kvízu.");
            isLoadingQuestions = false;
            return;
        }

        using var request = new HttpRequestMessage(HttpMethod.Get, $"/api/quizzes/{quizId.Value}");
        if (!string.IsNullOrWhiteSpace(questionsPassword))
        {
            request.Headers.Add("X-Quiz-Password", questionsPassword.Trim());
        }

        using var response = await HttpClient.SendAsync(request);
        if (response.IsSuccessStatusCode)
        {
            var detail = await response.Content.ReadFromJsonAsync<QuizDetailResponse>();
            revealedQuestions = detail?.Questions ?? [];
            SyncQuestionEditorsFromRevealedQuestions();
            hasLoadedQuestions = true;
            questionInfoMessage = $"Načteno otázek: {revealedQuestions.Count}.";
        }
        else
        {
            revealedQuestions = [];
            hasLoadedQuestions = false;
            questionApiError = await ReadApiErrorAsync(response);
        }

        isLoadingQuestions = false;
    }

    private async Task SaveQuestionAsync(QuestionEditorModel question)
    {
        questionApiError = null;
        questionInfoMessage = null;
        question.ValidationErrors = null;

        var quizId = GetQuizId();
        if (!quizId.HasValue)
        {
            questionApiError = new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Quiz ID není ve validním formátu GUID.");
            return;
        }

        question.ValidationErrors = ValidateQuestionEditor(question);
        if (question.ValidationErrors is not null)
        {
            questionApiError = new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Formulář obsahuje chyby. Opravte prosím zvýrazněná pole.");
            return;
        }

        if (string.IsNullOrWhiteSpace(questionsPassword) && string.IsNullOrWhiteSpace(storedOrganizerToken))
        {
            questionApiError = new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Pro úpravu otázky zadejte Administrátorské heslo kvízu nebo použijte uložený organizer token.");
            return;
        }

        var wasEditing = question.QuestionId.HasValue;
        var normalizedText = question.Text.Trim();
        var normalizedOptionA = question.OptionA.Trim();
        var normalizedOptionB = question.OptionB.Trim();
        var normalizedOptionC = question.OptionC.Trim();
        var normalizedOptionD = question.OptionD.Trim();
        isSavingQuestion = true;
        isDeletingQuestionAction = false;
        isSavingQuestionId = question.ClientId;

        HttpRequestMessage request;
        if (question.QuestionId.HasValue)
        {
            var updatePayload = new UpdateQuizQuestionRequest(
                normalizedText,
                question.TimeLimitSec!.Value,
                question.QuestionType,
                question.QuestionType == QuestionType.MultipleChoice ? question.CorrectOption : null,
                question.QuestionType == QuestionType.NumericClosest ? question.CorrectNumericValue : null,
                question.QuestionType == QuestionType.MultipleChoice ? normalizedOptionA : null,
                question.QuestionType == QuestionType.MultipleChoice ? normalizedOptionB : null,
                question.QuestionType == QuestionType.MultipleChoice ? normalizedOptionC : null,
                question.QuestionType == QuestionType.MultipleChoice ? normalizedOptionD : null,
                question.Order);

            request = new HttpRequestMessage(HttpMethod.Put, $"/api/quizzes/{quizId.Value}/questions/{question.QuestionId.Value}")
            {
                Content = JsonContent.Create(updatePayload)
            };
        }
        else
        {
            var addPayload = new AddQuizQuestionRequest(
                normalizedText,
                question.TimeLimitSec!.Value,
                question.QuestionType,
                question.QuestionType == QuestionType.MultipleChoice ? question.CorrectOption : null,
                question.QuestionType == QuestionType.NumericClosest ? question.CorrectNumericValue : null,
                question.QuestionType == QuestionType.MultipleChoice ? normalizedOptionA : null,
                question.QuestionType == QuestionType.MultipleChoice ? normalizedOptionB : null,
                question.QuestionType == QuestionType.MultipleChoice ? normalizedOptionC : null,
                question.QuestionType == QuestionType.MultipleChoice ? normalizedOptionD : null,
                question.Order);

            request = new HttpRequestMessage(HttpMethod.Post, $"/api/quizzes/{quizId.Value}/questions")
            {
                Content = JsonContent.Create(addPayload)
            };
        }

        if (!string.IsNullOrWhiteSpace(questionsPassword))
        {
            request.Headers.Add("X-Quiz-Password", questionsPassword.Trim());
        }

        ApplyOrganizerAuth(request);

        using var response = await HttpClient.SendAsync(request);
        request.Dispose();
        if (response.IsSuccessStatusCode)
        {
            if (hasLoadedQuestions || !string.IsNullOrWhiteSpace(questionsPassword))
            {
                await LoadQuestionsAsync();
            }
            else if (quizDetail is not null)
            {
                allowManualAddWithoutPassword = true;
                if (!question.QuestionId.HasValue)
                {
                    quizDetail = quizDetail with { QuestionCount = quizDetail.QuestionCount + 1 };
                    var createdQuestion = await response.Content.ReadFromJsonAsync<AddQuizQuestionResponse>();
                    question.QuestionId = createdQuestion?.QuestionId;
                    if (createdQuestion is not null)
                    {
                        question.Order = createdQuestion.OrderIndex + 1;
                    }
                    question.IsNew = false;
                }
            }

            if (questionApiError is null)
            {
                questionInfoMessage = wasEditing ? "Otázka byla úspěšně upravena." : "Otázka byla úspěšně přidána.";
            }
        }
        else
        {
            questionApiError = await ReadApiErrorAsync(response);
        }

        isSavingQuestionId = null;
        isDeletingQuestionAction = false;
        isSavingQuestion = false;
    }

    private async Task DeleteQuestionAsync(QuestionEditorModel question)
    {
        questionApiError = null;
        questionInfoMessage = null;

        if (!question.QuestionId.HasValue)
        {
            questionEditors.Remove(question);
            NormalizeQuestionOrders();
            return;
        }

        var quizId = GetQuizId();
        if (!quizId.HasValue)
        {
            questionApiError = new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Quiz ID není ve validním formátu GUID.");
            return;
        }

        if (string.IsNullOrWhiteSpace(questionsPassword) && string.IsNullOrWhiteSpace(storedOrganizerToken))
        {
            questionApiError = new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Pro smazání otázky zadejte Administrátorské heslo kvízu nebo použijte uložený organizer token.");
            return;
        }

        isSavingQuestion = true;
        isDeletingQuestionAction = true;
        isSavingQuestionId = question.ClientId;

        using var request = new HttpRequestMessage(HttpMethod.Delete, $"/api/quizzes/{quizId.Value}/questions/{question.QuestionId.Value}");
        if (!string.IsNullOrWhiteSpace(questionsPassword))
        {
            request.Headers.Add("X-Quiz-Password", questionsPassword.Trim());
        }

        ApplyOrganizerAuth(request);

        using var response = await HttpClient.SendAsync(request);
        if (response.IsSuccessStatusCode)
        {
            if (hasLoadedQuestions || !string.IsNullOrWhiteSpace(questionsPassword))
            {
                await LoadQuestionsAsync();
            }
            else
            {
                questionEditors.Remove(question);
                NormalizeQuestionOrders();
                if (quizDetail is not null && quizDetail.QuestionCount > 0)
                {
                    quizDetail = quizDetail with { QuestionCount = quizDetail.QuestionCount - 1 };
                }
            }

            questionInfoMessage = "Otázka byla úspěšně smazána.";
        }
        else
        {
            questionApiError = await ReadApiErrorAsync(response);
        }

        isSavingQuestionId = null;
        isDeletingQuestionAction = false;
        isSavingQuestion = false;
    }

    private void AddEmptyQuestion()
    {
        questionApiError = null;
        questionInfoMessage = null;

        NormalizeQuestionOrders();
        var nextOrder = GetNextAvailableQuestionOrder();

        questionEditors.Add(new QuestionEditorModel
        {
            Order = nextOrder,
            QuestionType = QuestionType.MultipleChoice,
            IsNew = true
        });

        NormalizeQuestionOrders();
    }

    private Task MoveQuestionUpAsync(QuestionEditorModel question)
    {
        return MoveQuestionAsync(question, -1);
    }

    private Task MoveQuestionDownAsync(QuestionEditorModel question)
    {
        return MoveQuestionAsync(question, 1);
    }

    private async Task MoveQuestionAsync(QuestionEditorModel question, int step)
    {
        questionApiError = null;
        questionInfoMessage = null;

        var ordered = questionEditors.OrderBy(x => x.Order).ToList();
        var currentIndex = ordered.FindIndex(x => x.ClientId == question.ClientId);
        if (currentIndex < 0)
        {
            return;
        }

        var targetIndex = currentIndex + step;
        if (targetIndex < 0 || targetIndex >= ordered.Count)
        {
            return;
        }

        (ordered[currentIndex], ordered[targetIndex]) = (ordered[targetIndex], ordered[currentIndex]);
        questionEditors = ordered;
        NormalizeQuestionOrders();

        await SaveQuestionOrderAsync();
    }

    private async Task SaveQuestionOrderAsync()
    {
        questionApiError = null;

        var quizId = GetQuizId();
        if (!quizId.HasValue)
        {
            questionApiError = new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Quiz ID není ve validním formátu GUID.");
            return;
        }

        if (string.IsNullOrWhiteSpace(questionsPassword) && string.IsNullOrWhiteSpace(storedOrganizerToken))
        {
            questionApiError = new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Pro úpravu pořadí otázek zadejte Administrátorské heslo kvízu nebo použijte uložený organizer token.");
            return;
        }

        isSavingQuestion = true;
        isDeletingQuestionAction = false;
        isSavingQuestionId = null;

        var persistedEditors = questionEditors
            .Where(x => x.QuestionId.HasValue)
            .OrderBy(x => x.Order)
            .ToList();

        for (var index = 0; index < persistedEditors.Count; index++)
        {
            var editor = persistedEditors[index];
            var temporaryOrder = persistedEditors.Count + index + 1;

            using var request = new HttpRequestMessage(HttpMethod.Put, $"/api/quizzes/{quizId.Value}/questions/{editor.QuestionId!.Value}")
            {
                Content = JsonContent.Create(new UpdateQuizQuestionRequest(
                    editor.Text.Trim(),
                    editor.TimeLimitSec ?? 30,
                    editor.QuestionType,
                    editor.QuestionType == QuestionType.MultipleChoice ? editor.CorrectOption : null,
                    editor.QuestionType == QuestionType.NumericClosest ? editor.CorrectNumericValue : null,
                    editor.QuestionType == QuestionType.MultipleChoice ? editor.OptionA.Trim() : null,
                    editor.QuestionType == QuestionType.MultipleChoice ? editor.OptionB.Trim() : null,
                    editor.QuestionType == QuestionType.MultipleChoice ? editor.OptionC.Trim() : null,
                    editor.QuestionType == QuestionType.MultipleChoice ? editor.OptionD.Trim() : null,
                    temporaryOrder))
            };

            if (!string.IsNullOrWhiteSpace(questionsPassword))
            {
                request.Headers.Add("X-Quiz-Password", questionsPassword.Trim());
            }

            ApplyOrganizerAuth(request);

            using var response = await HttpClient.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                questionApiError = await ReadApiErrorAsync(response);
                isSavingQuestionId = null;
                isDeletingQuestionAction = false;
                isSavingQuestion = false;
                return;
            }
        }

        for (var index = 0; index < persistedEditors.Count; index++)
        {
            var editor = persistedEditors[index];
            var finalOrder = index + 1;

            using var request = new HttpRequestMessage(HttpMethod.Put, $"/api/quizzes/{quizId.Value}/questions/{editor.QuestionId!.Value}")
            {
                Content = JsonContent.Create(new UpdateQuizQuestionRequest(
                    editor.Text.Trim(),
                    editor.TimeLimitSec ?? 30,
                    editor.QuestionType,
                    editor.QuestionType == QuestionType.MultipleChoice ? editor.CorrectOption : null,
                    editor.QuestionType == QuestionType.NumericClosest ? editor.CorrectNumericValue : null,
                    editor.QuestionType == QuestionType.MultipleChoice ? editor.OptionA.Trim() : null,
                    editor.QuestionType == QuestionType.MultipleChoice ? editor.OptionB.Trim() : null,
                    editor.QuestionType == QuestionType.MultipleChoice ? editor.OptionC.Trim() : null,
                    editor.QuestionType == QuestionType.MultipleChoice ? editor.OptionD.Trim() : null,
                    finalOrder))
            };

            if (!string.IsNullOrWhiteSpace(questionsPassword))
            {
                request.Headers.Add("X-Quiz-Password", questionsPassword.Trim());
            }

            ApplyOrganizerAuth(request);

            using var response = await HttpClient.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                questionApiError = await ReadApiErrorAsync(response);
                isSavingQuestionId = null;
                isDeletingQuestionAction = false;
                isSavingQuestion = false;
                return;
            }
        }

        questionInfoMessage = "Pořadí otázek bylo uloženo.";
        isSavingQuestionId = null;
        isDeletingQuestionAction = false;
        isSavingQuestion = false;
    }

    private static void OnQuestionTypeChanged(QuestionEditorModel question)
    {
        question.ValidationErrors = null;

        if (question.QuestionType == QuestionType.MultipleChoice)
        {
            question.CorrectNumericValue = null;
        }
        else
        {
            question.CorrectOption = null;
        }
    }

    private async Task StartQuizAsync()
    {
        RemoveUnsavedDraftQuestionsBeforeStart();

        apiError = null;
        infoMessage = null;
        isCreatingSession = true;

        var normalizedJoinCode = joinCode.Trim().ToUpperInvariant();
        if (string.IsNullOrWhiteSpace(normalizedJoinCode))
        {
            apiError = new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Pro spuštění zadejte join kód.");
            isCreatingSession = false;
            return;
        }

        if (normalizedJoinCode.Length < 4)
        {
            apiError = new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Join kód musí mít alespoň 4 znaky.");
            isCreatingSession = false;
            return;
        }

        var quizId = GetQuizId();
        if (!quizId.HasValue)
        {
            apiError = new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Quiz ID není ve validním formátu GUID.");
            isCreatingSession = false;
            return;
        }

        await LoadStoredTokenAsync(quizId.Value);

        using var request = new HttpRequestMessage(HttpMethod.Post, $"/api/quizzes/{quizId.Value}/sessions")
        {
            Content = JsonContent.Create(new CreateSessionRequest(normalizedJoinCode))
        };

        ApplyOrganizerAuth(request);

        using var response = await HttpClient.SendAsync(request);
        if (response.IsSuccessStatusCode)
        {
            var createdSession = await response.Content.ReadFromJsonAsync<CreateSessionResponse>();
            if (createdSession is null)
            {
                apiError = new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Nepodařilo se načíst založenou session.");
                isCreatingSession = false;
                return;
            }

            var startModeQuery = isQuizTimerEnabled ? string.Empty : "&startMode=without-timer";
            NavigationManager.NavigateTo($"/organizator/session/cekarna/{createdSession.SessionId}?quizId={quizId.Value}{startModeQuery}");
            return;
        }
        else
        {
            apiError = await ReadApiErrorAsync(response);
        }

        isCreatingSession = false;
    }

    private void RemoveUnsavedDraftQuestionsBeforeStart()
    {
        var removedCount = questionEditors.RemoveAll(x => !x.QuestionId.HasValue);
        if (removedCount == 0)
        {
            return;
        }

        NormalizeQuestionOrders();
        questionInfoMessage = removedCount == 1
            ? "Neuložená nová otázka byla před spuštěním kvízu odebrána."
            : "Neuložené nové otázky byly před spuštěním kvízu odebrány.";
    }

    private async Task DeleteQuizAsync()
    {
        apiError = null;
        infoMessage = null;
        isDeleting = true;

        var quizId = GetQuizId();
        if (!quizId.HasValue)
        {
            apiError = new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Quiz ID není ve validním formátu GUID.");
            isDeleting = false;
            return;
        }

        if (string.IsNullOrWhiteSpace(deletePassword))
        {
            apiError = new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Pro smazání je nutné zadat Administrátorké heslo kvízu.");
            isDeleting = false;
            return;
        }

        await LoadStoredTokenAsync(quizId.Value);

        using var request = new HttpRequestMessage(HttpMethod.Delete, $"/api/quizzes/{quizId.Value}");
        request.Headers.Add("X-Quiz-Password", deletePassword.Trim());

        if (!string.IsNullOrWhiteSpace(storedOrganizerToken))
        {
            request.Headers.Add("X-Organizer-Token", storedOrganizerToken);
        }

        using var response = await HttpClient.SendAsync(request);
        if (response.IsSuccessStatusCode)
        {
            await OrganizerQuizLocalStore.RemoveAsync(quizId.Value);
            NavigationManager.NavigateTo("/organizator");
            return;
        }

        apiError = await ReadApiErrorAsync(response);
        isDeleting = false;
    }

    private async Task LoadStoredTokenAsync(Guid quizId)
    {
        var storedQuiz = await OrganizerQuizLocalStore.FindByQuizIdAsync(quizId);
        storedOrganizerToken = storedQuiz?.QuizOrganizerToken;
    }

    private Guid? GetQuizId() => QuizId;

    private void ResetRevealedQuestionsState()
    {
        questionsPassword = string.Empty;
        questionInfoMessage = null;
        questionApiError = null;
        hasLoadedQuestions = false;
        allowManualAddWithoutPassword = false;
        revealedQuestions = [];
        questionEditors = [];
    }

    private void SyncQuestionEditorsFromRevealedQuestions()
    {
        questionEditors = revealedQuestions
            .OrderBy(x => x.OrderIndex)
            .Select(x => new QuestionEditorModel
            {
                QuestionId = x.QuestionId,
                Order = x.OrderIndex + 1,
                Text = x.Text,
                TimeLimitSec = x.TimeLimitSec,
                QuestionType = x.QuestionType,
                CorrectOption = x.CorrectOption,
                CorrectNumericValue = NormalizeDecimalForUi(x.CorrectNumericValue),
                OptionA = x.Options.FirstOrDefault(o => o.OptionKey == OptionKey.A)?.Text ?? string.Empty,
                OptionB = x.Options.FirstOrDefault(o => o.OptionKey == OptionKey.B)?.Text ?? string.Empty,
                OptionC = x.Options.FirstOrDefault(o => o.OptionKey == OptionKey.C)?.Text ?? string.Empty,
                OptionD = x.Options.FirstOrDefault(o => o.OptionKey == OptionKey.D)?.Text ?? string.Empty,
                IsNew = false
            })
            .ToList();

        NormalizeQuestionOrders();
    }

    private int GetNextAvailableQuestionOrder()
    {
        var usedOrders = questionEditors
            .Select(x => x.Order)
            .Where(x => x > 0)
            .ToHashSet();

        var nextOrder = 1;
        while (usedOrders.Contains(nextOrder))
        {
            nextOrder++;
        }

        return nextOrder;
    }

    private void NormalizeQuestionOrders()
    {
        for (var i = 0; i < questionEditors.Count; i++)
        {
            questionEditors[i].Order = i + 1;
        }
    }

    private static bool TryGetQuestionValidationMessage(QuestionEditorModel question, string fieldName, out string message)
    {
        message = string.Empty;

        if (question.ValidationErrors is null || !question.ValidationErrors.TryGetValue(fieldName, out var messages) || messages.Length == 0)
        {
            return false;
        }

        message = messages[0];
        return true;
    }

    private static Dictionary<string, string[]>? ValidateQuestionEditor(QuestionEditorModel question)
    {
        var errors = new Dictionary<string, string[]>(StringComparer.Ordinal);

        if (question.Order < 1)
        {
            errors[nameof(QuestionEditorModel.Order)] = ["Pořadí otázky musí být alespoň 1."];
        }

        if (string.IsNullOrWhiteSpace(question.Text))
        {
            errors[nameof(QuestionEditorModel.Text)] = ["Zadejte text otázky."];
        }
        else if (question.Text.Trim().Length > 1500)
        {
            errors[nameof(QuestionEditorModel.Text)] = ["Text otázky je příliš dlouhý (max. 1500 znaků)."];
        }

        if (!question.TimeLimitSec.HasValue || question.TimeLimitSec.Value < 10 || question.TimeLimitSec.Value > 300)
        {
            errors[nameof(QuestionEditorModel.TimeLimitSec)] = ["Časový limit musí být mezi 10 a 300 sekundami."];
        }

        if (question.QuestionType == QuestionType.MultipleChoice)
        {
            ValidateOption(question.OptionA, nameof(QuestionEditorModel.OptionA), "Vyplňte odpověď A.", errors);
            ValidateOption(question.OptionB, nameof(QuestionEditorModel.OptionB), "Vyplňte odpověď B.", errors);
            ValidateOption(question.OptionC, nameof(QuestionEditorModel.OptionC), "Vyplňte odpověď C.", errors);
            ValidateOption(question.OptionD, nameof(QuestionEditorModel.OptionD), "Vyplňte odpověď D.", errors);

            if (!question.CorrectOption.HasValue)
            {
                errors[nameof(QuestionEditorModel.CorrectOption)] = ["Vyberte správnou odpověď."];
            }
        }
        else if (!question.CorrectNumericValue.HasValue)
        {
            errors[nameof(QuestionEditorModel.CorrectNumericValue)] = ["Zadejte správnou číselnou hodnotu."];
        }

        return errors.Count == 0 ? null : errors;
    }

    private static void ValidateOption(string? optionValue, string fieldName, string requiredMessage, IDictionary<string, string[]> errors)
    {
        if (string.IsNullOrWhiteSpace(optionValue))
        {
            errors[fieldName] = [requiredMessage];
            return;
        }

        if (optionValue.Trim().Length > 500)
        {
            errors[fieldName] = ["Text odpovědi je příliš dlouhý (max. 500 znaků)."];
        }
    }

    private static decimal? NormalizeDecimalForUi(decimal? value)
    {
        if (!value.HasValue)
        {
            return null;
        }

        var normalized = value.Value.ToString("0.#############################", System.Globalization.CultureInfo.InvariantCulture);
        return decimal.Parse(normalized, System.Globalization.CultureInfo.InvariantCulture);
    }

    private sealed class QuestionEditorModel
    {
        public Guid ClientId { get; init; } = Guid.NewGuid();
        public Guid? QuestionId { get; set; }
        public int Order { get; set; }
        public string Text { get; set; } = string.Empty;
        public int? TimeLimitSec { get; set; }
        public QuestionType QuestionType { get; set; }
        public OptionKey? CorrectOption { get; set; }
        public decimal? CorrectNumericValue { get; set; }
        public string OptionA { get; set; } = string.Empty;
        public string OptionB { get; set; } = string.Empty;
        public string OptionC { get; set; } = string.Empty;
        public string OptionD { get; set; } = string.Empty;
        public bool IsNew { get; set; }
        public Dictionary<string, string[]>? ValidationErrors { get; set; }
    }

    private static string DecodeCsvContent(byte[] csvBytes)
    {
        if (csvBytes.Length == 0)
        {
            return string.Empty;
        }

        try
        {
            return new System.Text.UTF8Encoding(false, true).GetString(csvBytes);
        }
        catch (System.Text.DecoderFallbackException)
        {
        }

        return System.Text.Encoding.GetEncoding(1250).GetString(csvBytes);
    }

    private void ApplyOrganizerAuth(HttpRequestMessage request)
    {
        if (!string.IsNullOrWhiteSpace(storedOrganizerToken))
        {
            request.Headers.Add("X-Organizer-Token", storedOrganizerToken);
        }
    }

    private static async Task<ApiErrorResponse> ReadApiErrorAsync(HttpResponseMessage response)
    {
        var apiError = await response.Content.ReadFromJsonAsync<ApiErrorResponse>();
        if (apiError is not null)
        {
            return apiError;
        }

        return new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Operace selhala.");
    }
