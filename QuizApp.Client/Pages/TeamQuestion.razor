@page "/tym/otazka"
@page "/tym/otazka/{SessionId:guid}"
@using Microsoft.AspNetCore.SignalR.Client
@implements IAsyncDisposable
@inject HttpClient HttpClient
@inject TeamSessionLocalStore TeamSessionLocalStore
@inject NavigationManager NavigationManager
@inject ActiveSessionState ActiveSessionState

<PageTitle>@PageHeading</PageTitle>

<h1>@PageHeading</h1>

@if (snapshot?.Status is SessionStatus.Running or SessionStatus.Paused && snapshot.CurrentQuestion is not null)
{
    <p class="text-muted">Odpověď lze během otázky odeslat pouze jednou.</p>
}
<p class="text-muted">Realtime: @(isRealtimeConnected ? "připojeno" : "odpojeno")@(isFallbackPolling ? " (záložní polling aktivní)" : string.Empty)</p>

@if (!string.IsNullOrWhiteSpace(infoMessage))
{
    <div class="alert alert-info" role="alert">@infoMessage</div>
}

@if (apiError is not null)
{
    <div class="alert alert-danger" role="alert">@apiError.Message</div>
}

@if (identity is null)
{
    <div class="alert alert-warning" role="alert">
        Chybí uložená týmová identita. Nejprve se připojte do session.
    </div>

    <a class="btn btn-outline-primary" href="/tym/pripojeni">Přejít na připojení týmu</a>
}
else if (snapshot is null)
{
    <button class="btn btn-primary" type="button" disabled="@isLoading" @onclick="LoadSnapshotAsync">
        @(isLoading ? "Načítám..." : "Načíst otázku")
    </button>
}
else if (snapshot.Status == SessionStatus.Waiting)
{
    <div class="alert alert-warning" role="alert">Session ještě neběží. Počkejte v čekárně týmu.</div>
    <a class="btn btn-outline-primary" href="@($"/tym/cekarna/{snapshot.SessionId}")">Zpět do čekárny</a>
}
else if (snapshot.Status is SessionStatus.Cancelled)
{
    <div class="alert alert-secondary" role="alert">Hra byla zrušena.</div>
    <a class="btn btn-outline-primary" href="/">Zpět na úvod</a>
}
else if (snapshot.Status is SessionStatus.Finished)
{
    @if (!snapshot.ResultsPublished)
    {
        <div class="alert alert-info mb-2" role="alert">Výsledky zatím nebyly zveřejněny organizátorem.</div>
    }

    <button class="btn btn-primary" type="button" disabled="@(!snapshot.ResultsPublished)" @onclick="GoToResults">
        Zobrazit výsledky
    </button>
}
else if (snapshot.CurrentQuestion is null)
{
    <div class="alert alert-warning" role="alert">Aktuálně není aktivní otázka. Vyčkejte na další průběh hry.</div>
}
else
{
    <section class="card mb-3">
        <div class="card-body">
            <h2 class="h5 fw-normal mb-2">Otázka číslo: @((snapshot.CurrentQuestionIndex ?? 0) + 1)</h2>
            <p class="mb-2"><strong>@snapshot.CurrentQuestion.Text</strong></p>
            @if (snapshot.Status == SessionStatus.Paused)
            {
                <p class="mb-1 text-warning"><strong>Hra je pozastavena organizátorem.</strong></p>
            }
            @if (snapshot.QuestionDeadlineUtc.HasValue)
            {
                @if (remainingSeconds > 0)
                {
                    <p class="mb-0 fs-4"><strong>⏱ Zbývá:</strong> @remainingSeconds s</p>
                }
                else
                {
                    <p class="mb-0 fs-4 text-danger"><strong>⏱ Čas vypršel</strong></p>
                }
            }
        </div>
    </section>

    @if (submittedOption.HasValue || submittedNumericValue.HasValue)
    {
        <div class="alert alert-success" role="alert">
            @if (submittedOption.HasValue)
            {
                <span>Odpověď <strong>@submittedOption</strong> byla odeslána. Odpověď již nelze změnit.</span>
            }
            else
            {
                <span>Číselný tip <strong>@FormatDecimal(submittedNumericValue)</strong> byl odeslán. Odpověď již nelze změnit.</span>
            }
        </div>
    }

    @if (snapshot.CurrentQuestion.QuestionType == QuestionType.MultipleChoice)
    {
        <div class="d-grid gap-2">
            @foreach (var option in snapshot.CurrentQuestion.Options.OrderBy(option => option.OptionKey))
            {
                <button class="btn btn-outline-primary text-start" type="button" disabled="@(!CanSubmitAnswer)" @onclick="() => SubmitAnswerAsync(option.OptionKey)">
                    <strong>@option.OptionKey</strong> — @option.Text
                </button>
            }
        </div>
    }
    else
    {
        <div class="row g-2 align-items-end justify-content-center">
            <div class="col-sm-8 col-md-6">
                <label class="form-label" for="numericTip">Zadejte číselný tip</label>
                <input id="numericTip"
                       class="form-control"
                       value="@numericTipInput"
                       @oninput="OnNumericTipInput"
                       disabled="@(!CanSubmitAnswer)" />
            </div>
            <div class="col-sm-4 col-md-3">
                <button class="btn btn-primary w-100" type="button" disabled="@(!CanSubmitAnswer || !numericTip.HasValue)" @onclick="SubmitNumericAnswerAsync">
                    Odeslat tip
                </button>
            </div>
        </div>
    }
}

@code {
    [Parameter]
    public Guid? SessionId { get; set; }

    [SupplyParameterFromQuery]
    public Guid? TeamId { get; set; }

    private StoredTeamIdentity? identity;
    private SessionStateSnapshotResponse? snapshot;
    private OptionKey? submittedOption;
    private decimal? submittedNumericValue;
    private decimal? numericTip;
    private string numericTipInput = string.Empty;
    private ApiErrorResponse? apiError;
    private string? infoMessage;
    private bool isLoading;
    private bool isRealtimeConnected;

    private HubConnection? hubConnection;
    private Guid? realtimeSessionId;
    private System.Threading.Timer? countdownTimer;
    private System.Threading.Timer? heartbeatTimer;
    private System.Threading.Timer? fallbackPollTimer;
    private System.Threading.Timer? pendingSubmitRetryTimer;
    private int remainingSeconds;
    private bool isHeartbeatInFlight;
    private bool isFallbackPolling;
    private bool isFallbackPollInFlight;
    private bool isPendingSubmitInFlight;
    private PendingSubmitItem? pendingSubmit;
    private const int FallbackPollIntervalSeconds = 3;

    private string PageHeading => snapshot?.Status is SessionStatus.Finished ? "Konec kvízu" : "Otázka";

    private bool CanSubmitAnswer => snapshot?.Status == SessionStatus.Running
        && !snapshot.IsCurrentQuestionAnsweringClosed
        && !submittedOption.HasValue
        && !submittedNumericValue.HasValue
        && pendingSubmit is null;

    protected override async Task OnParametersSetAsync()
    {
        apiError = null;
        infoMessage = null;

        if (!SessionId.HasValue)
        {
            return;
        }

        identity = await TeamSessionLocalStore.FindIdentityAsync(SessionId.Value, TeamId);
        if (identity is null)
        {
            apiError = new ApiErrorResponse(ApiErrorCode.MissingAuthToken, "Chybí uložená týmová identita pro tuto session.");
            return;
        }

        await LoadSnapshotAsync();
        var realtimeReady = await EnsureRealtimeConnectionAsync(SessionId.Value);
        if (!realtimeReady)
        {
            StartFallbackPolling("Realtime připojení není dostupné. Běží záložní obnovování stavu.");
        }
        RestartCountdownTimer();
        StartHeartbeatTimer();
    }

    private async Task LoadSnapshotAsync()
    {
        if (!SessionId.HasValue || identity is null)
        {
            return;
        }

        isLoading = true;
        apiError = null;

        using var request = new HttpRequestMessage(HttpMethod.Get, $"/api/sessions/{SessionId.Value}/state?teamId={identity.TeamId}");
        request.Headers.Add("X-Team-Reconnect-Token", identity.TeamReconnectToken);

        using var response = await HttpClient.SendAsync(request);
        if (response.IsSuccessStatusCode)
        {
            var loadedSnapshot = await response.Content.ReadFromJsonAsync<SessionStateSnapshotResponse>();
            if (!TryApplySnapshot(loadedSnapshot))
            {
                isLoading = false;
                return;
            }

            await ReloadSubmittedAnswerAsync();
            HandlePendingSubmitSnapshotState();
            UpdateActiveSessionState();
        }
        else
        {
            snapshot = null;
            submittedOption = null;
            submittedNumericValue = null;
            apiError = await ReadApiErrorAsync(response);
            UpdateActiveSessionState();
        }

        isLoading = false;
    }

    private async Task SubmitAnswerAsync(OptionKey option)
    {
        if (!SessionId.HasValue || identity is null || snapshot?.CurrentQuestion is null || submittedOption.HasValue || pendingSubmit is not null)
        {
            return;
        }

        await QueuePendingSubmitAsync(option, null);
    }

    private async Task SubmitNumericAnswerAsync()
    {
        if (!SessionId.HasValue || identity is null || snapshot?.CurrentQuestion is null || !numericTip.HasValue || submittedOption.HasValue || submittedNumericValue.HasValue || pendingSubmit is not null)
        {
            return;
        }

        await QueuePendingSubmitAsync(null, numericTip.Value);
    }

    private async Task QueuePendingSubmitAsync(OptionKey? option, decimal? numericValue)
    {
        if (!SessionId.HasValue || identity is null || snapshot?.CurrentQuestion is null)
        {
            return;
        }

        pendingSubmit = new PendingSubmitItem(
            snapshot.CurrentQuestion.QuestionId,
            option,
            numericValue,
            Guid.NewGuid(),
            0,
            DateTimeOffset.UtcNow);

        apiError = null;
        infoMessage = "Odesílám odpověď...";

        await TryProcessPendingSubmitAsync();
    }

    private async Task TryProcessPendingSubmitAsync()
    {
        if (!SessionId.HasValue || identity is null || pendingSubmit is null || isPendingSubmitInFlight)
        {
            return;
        }

        if (DateTimeOffset.UtcNow < pendingSubmit.NextAttemptAtUtc)
        {
            SchedulePendingSubmitRetry(pendingSubmit.NextAttemptAtUtc - DateTimeOffset.UtcNow);
            return;
        }

        isPendingSubmitInFlight = true;
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Post, $"/api/sessions/{SessionId.Value}/answers")
            {
                Content = JsonContent.Create(new SubmitAnswerRequest(
                    identity.TeamId,
                    pendingSubmit.QuestionId,
                    pendingSubmit.SelectedOption,
                    pendingSubmit.NumericValue,
                    pendingSubmit.ClientRequestId))
            };

            request.Headers.Add("X-Team-Reconnect-Token", identity.TeamReconnectToken);

            using var response = await HttpClient.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                await ConfirmPendingSubmitAcceptedAsync();
                return;
            }

            var error = await ReadApiErrorAsync(response);
            if (error.Code == ApiErrorCode.AlreadyAnswered)
            {
                await ConfirmPendingSubmitAlreadyAnsweredAsync();
                return;
            }

            if (IsRetryableSubmitError(error.Code))
            {
                SchedulePendingSubmitRetry(ComputeRetryDelay(IncrementPendingAttempt()));
                infoMessage = "Odeslání odpovědi se nepodařilo, proběhne automatický pokus o opakování.";
                return;
            }

            apiError = error;
            infoMessage = null;
            ClearPendingSubmit();
        }
        catch (HttpRequestException)
        {
            SchedulePendingSubmitRetry(ComputeRetryDelay(IncrementPendingAttempt()));
            infoMessage = "Spojení není dostupné, odpověď bude odeslána automaticky po obnovení sítě.";
        }
        catch (TaskCanceledException)
        {
            SchedulePendingSubmitRetry(ComputeRetryDelay(IncrementPendingAttempt()));
            infoMessage = "Čekám na obnovení spojení, odpověď zkusím odeslat znovu.";
        }
        finally
        {
            isPendingSubmitInFlight = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ConfirmPendingSubmitAcceptedAsync()
    {
        if (!SessionId.HasValue || identity is null || pendingSubmit is null)
        {
            return;
        }

        var acceptedSubmit = pendingSubmit;

        await TeamSessionLocalStore.SaveSubmittedAnswerAsync(
            SessionId.Value,
            identity.TeamId,
            acceptedSubmit.QuestionId,
            acceptedSubmit.SelectedOption,
            acceptedSubmit.NumericValue);

        submittedOption = acceptedSubmit.SelectedOption;
        submittedNumericValue = acceptedSubmit.NumericValue;
        infoMessage = null;
        apiError = null;
        ClearPendingSubmit();
    }

    private async Task ConfirmPendingSubmitAlreadyAnsweredAsync()
    {
        if (!SessionId.HasValue || identity is null || pendingSubmit is null)
        {
            return;
        }

        var resolvedSubmit = pendingSubmit;

        await LoadSnapshotAsync();

        await TeamSessionLocalStore.SaveSubmittedAnswerAsync(
            SessionId.Value,
            identity.TeamId,
            resolvedSubmit.QuestionId,
            resolvedSubmit.SelectedOption,
            resolvedSubmit.NumericValue);

        submittedOption = resolvedSubmit.SelectedOption;
        submittedNumericValue = resolvedSubmit.NumericValue;
        infoMessage = "Odpověď již byla dříve odeslána (stav potvrzen snapshotem).";
        apiError = null;
        ClearPendingSubmit();
    }

    private void HandlePendingSubmitSnapshotState()
    {
        if (pendingSubmit is null || snapshot is null)
        {
            return;
        }

        if (snapshot.Status != SessionStatus.Running
            || snapshot.IsCurrentQuestionAnsweringClosed
            || snapshot.CurrentQuestion is null
            || snapshot.CurrentQuestion.QuestionId != pendingSubmit.QuestionId)
        {
            infoMessage = "Aktuální otázka už není aktivní. Odpověď nebylo možné znovu odeslat.";
            ClearPendingSubmit();
        }
    }

    private int IncrementPendingAttempt()
    {
        if (pendingSubmit is null)
        {
            return 0;
        }

        pendingSubmit = pendingSubmit with { RetryAttempt = pendingSubmit.RetryAttempt + 1 };
        return pendingSubmit.RetryAttempt;
    }

    private void SchedulePendingSubmitRetry(TimeSpan delay)
    {
        if (pendingSubmit is null)
        {
            return;
        }

        if (delay < TimeSpan.FromSeconds(1))
        {
            delay = TimeSpan.FromSeconds(1);
        }

        pendingSubmit = pendingSubmit with
        {
            NextAttemptAtUtc = DateTimeOffset.UtcNow.Add(delay)
        };

        pendingSubmitRetryTimer?.Dispose();
        pendingSubmitRetryTimer = new System.Threading.Timer(_ =>
        {
            _ = InvokeAsync(TryProcessPendingSubmitAsync);
        }, null, delay, System.Threading.Timeout.InfiniteTimeSpan);
    }

    private static TimeSpan ComputeRetryDelay(int retryAttempt)
    {
        var seconds = Math.Min(8, (int)Math.Pow(2, Math.Max(0, retryAttempt)));
        return TimeSpan.FromSeconds(seconds);
    }

    private static bool IsRetryableSubmitError(ApiErrorCode errorCode)
    {
        return errorCode is ApiErrorCode.RateLimited;
    }

    private void ClearPendingSubmit()
    {
        pendingSubmit = null;
        pendingSubmitRetryTimer?.Dispose();
        pendingSubmitRetryTimer = null;
    }

    private async Task ReloadSubmittedAnswerAsync()
    {
        if (!SessionId.HasValue || identity is null || snapshot?.CurrentQuestion is null)
        {
            submittedOption = null;
            return;
        }

        var submittedAnswer = await TeamSessionLocalStore.FindSubmittedAnswerAsync(SessionId.Value, identity.TeamId, snapshot.CurrentQuestion.QuestionId);
        submittedOption = submittedAnswer?.SelectedOption;
        submittedNumericValue = submittedAnswer?.NumericValue;
        numericTip = submittedNumericValue;
        numericTipInput = FormatDecimal(submittedNumericValue) == "-" ? string.Empty : FormatDecimal(submittedNumericValue);
    }

    private void OnNumericTipInput(ChangeEventArgs args)
    {
        numericTipInput = args.Value?.ToString() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(numericTipInput))
        {
            numericTip = null;
            return;
        }

        if (decimal.TryParse(numericTipInput, System.Globalization.NumberStyles.Number, System.Globalization.CultureInfo.CurrentCulture, out var parsedCurrentCulture)
            || decimal.TryParse(numericTipInput, System.Globalization.NumberStyles.Number, System.Globalization.CultureInfo.InvariantCulture, out parsedCurrentCulture))
        {
            numericTip = parsedCurrentCulture;
            return;
        }

        numericTip = null;
    }

    private void GoToResults()
    {
        if (snapshot is null || !snapshot.ResultsPublished || identity is null)
        {
            return;
        }

        NavigationManager.NavigateTo($"/session/vysledky/{snapshot.SessionId}?teamId={identity.TeamId}");
    }

    private void RestartCountdownTimer()
    {
        countdownTimer?.Dispose();
        countdownTimer = null;

        UpdateRemainingSeconds();

        if (snapshot?.QuestionDeadlineUtc is null || snapshot.Status != SessionStatus.Running)
        {
            return;
        }

        countdownTimer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(() =>
            {
                UpdateRemainingSeconds();
                StateHasChanged();
            });
        }, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    private void UpdateRemainingSeconds()
    {
        if (snapshot?.QuestionDeadlineUtc is null)
        {
            remainingSeconds = 0;
            return;
        }

        var diff = snapshot.QuestionDeadlineUtc.Value - DateTimeOffset.UtcNow;
        remainingSeconds = Math.Max(0, (int)Math.Ceiling(diff.TotalSeconds));
    }

    private async Task<bool> EnsureRealtimeConnectionAsync(Guid sessionId)
    {
        if (hubConnection is null)
        {
            hubConnection = new HubConnectionBuilder()
                .WithUrl(new Uri(HttpClient.BaseAddress!, "/hubs/sessions"))
                .WithAutomaticReconnect(new ReconnectWithinSixtySecondsPolicy())
                .Build();

            hubConnection.On(RealtimeEventName.QuestionChanged.ToWireName(), async () => await ReloadSnapshotFromRealtimeAsync(string.Empty));
            hubConnection.On(RealtimeEventName.SessionFinished.ToWireName(), async () => await ReloadSnapshotFromRealtimeAsync("Hra byla ukončena."));
            hubConnection.On(RealtimeEventName.SessionCancelled.ToWireName(), async () => await ReloadSnapshotFromRealtimeAsync(string.Empty));
            hubConnection.On(RealtimeEventName.ResultsReady.ToWireName(), async () => await ReloadSnapshotFromRealtimeAsync("Výsledky jsou připravené."));

            hubConnection.Reconnecting += _ =>
            {
                isRealtimeConnected = false;
                StartFallbackPolling("Realtime spojení se obnovuje. Běží záložní obnovování stavu.");
                return InvokeAsync(StateHasChanged);
            };

            hubConnection.Reconnected += async _ =>
            {
                var reconnectSessionId = realtimeSessionId ?? sessionId;
                var subscribed = await SubscribeRealtimeSessionAsync(reconnectSessionId);
                if (!subscribed)
                {
                    isRealtimeConnected = false;
                    StartFallbackPolling("Realtime připojení se nepodařilo obnovit. Běží záložní obnovování stavu.");
                    return;
                }

                isRealtimeConnected = true;
                StopFallbackPolling();
                await ReloadSnapshotFromRealtimeAsync("Realtime připojení bylo obnoveno.");
            };

            hubConnection.Closed += _ =>
            {
                isRealtimeConnected = false;
                StartFallbackPolling("Realtime spojení bylo ukončeno. Běží záložní obnovování stavu.");
                return InvokeAsync(StateHasChanged);
            };
        }

        try
        {
            if (hubConnection.State == HubConnectionState.Disconnected)
            {
                await hubConnection.StartAsync();
            }

            var subscribed = await SubscribeRealtimeSessionAsync(sessionId);
            isRealtimeConnected = subscribed;
            if (subscribed)
            {
                StopFallbackPolling();
            }
            else
            {
                StartFallbackPolling("Realtime připojení není dostupné. Běží záložní obnovování stavu.");
            }

            return subscribed;
        }
        catch
        {
            isRealtimeConnected = false;
            StartFallbackPolling("Realtime připojení není dostupné. Běží záložní obnovování stavu.");
            return false;
        }
    }

    private async Task<bool> SubscribeRealtimeSessionAsync(Guid sessionId)
    {
        if (hubConnection is null)
        {
            return false;
        }

        if (realtimeSessionId.HasValue && realtimeSessionId.Value != sessionId)
        {
            await hubConnection.InvokeAsync("UnsubscribeFromSessionAsync", realtimeSessionId.Value);
        }

        var subscribed = await hubConnection.InvokeAsync<bool>("SubscribeToSessionAsync", sessionId);
        if (!subscribed)
        {
            return false;
        }

        realtimeSessionId = sessionId;
        await InvokeAsync(StateHasChanged);
        return true;
    }

    private void StartFallbackPolling(string message)
    {
        if (isFallbackPolling)
        {
            return;
        }

        isFallbackPolling = true;
        infoMessage = message;

        fallbackPollTimer = new System.Threading.Timer(_ =>
        {
            _ = InvokeAsync(RunFallbackPollAsync);
        }, null, TimeSpan.FromSeconds(FallbackPollIntervalSeconds), TimeSpan.FromSeconds(FallbackPollIntervalSeconds));
    }

    private void StopFallbackPolling()
    {
        fallbackPollTimer?.Dispose();
        fallbackPollTimer = null;
        isFallbackPolling = false;
        isFallbackPollInFlight = false;
    }

    private async Task RunFallbackPollAsync()
    {
        if (isFallbackPollInFlight || !SessionId.HasValue)
        {
            return;
        }

        isFallbackPollInFlight = true;
        try
        {
            await LoadSnapshotAsync();
            RestartCountdownTimer();

            var realtimeReady = await EnsureRealtimeConnectionAsync(SessionId.Value);
            if (realtimeReady)
            {
                StopFallbackPolling();
                infoMessage = "Realtime připojení bylo obnoveno.";
            }

            await TryProcessPendingSubmitAsync();
        }
        finally
        {
            isFallbackPollInFlight = false;
        }
    }

    private async Task ReloadSnapshotFromRealtimeAsync(string message)
    {
        await InvokeAsync(async () =>
        {
            await LoadSnapshotAsync();
            if (snapshot is not null)
            {
                infoMessage = message;
            }

            RestartCountdownTimer();
            await TryProcessPendingSubmitAsync();
            StateHasChanged();
        });
    }

    private bool TryApplySnapshot(SessionStateSnapshotResponse? incomingSnapshot)
    {
        if (incomingSnapshot is null)
        {
            return false;
        }

        if (snapshot is not null && incomingSnapshot.Version <= snapshot.Version)
        {
            return false;
        }

        snapshot = incomingSnapshot;
        return true;
    }

    private static async Task<ApiErrorResponse> ReadApiErrorAsync(HttpResponseMessage response)
    {
        var error = await response.Content.ReadFromJsonAsync<ApiErrorResponse>();
        return error ?? new ApiErrorResponse(ApiErrorCode.ValidationFailed, "Načtení otázky selhalo.");
    }

    private static string FormatDecimal(decimal? value)
    {
        if (!value.HasValue)
        {
            return "-";
        }

        return value.Value.ToString("0.############################", System.Globalization.CultureInfo.CurrentCulture);
    }

    public async ValueTask DisposeAsync()
    {
        ActiveSessionState.Clear();

        countdownTimer?.Dispose();
        countdownTimer = null;
        StopHeartbeatTimer();
        StopFallbackPolling();
        ClearPendingSubmit();

        if (hubConnection is null)
        {
            return;
        }

        if (realtimeSessionId.HasValue && hubConnection.State == HubConnectionState.Connected)
        {
            await hubConnection.InvokeAsync("UnsubscribeFromSessionAsync", realtimeSessionId.Value);
        }

        await hubConnection.DisposeAsync();
    }

    private sealed record PendingSubmitItem(
        Guid QuestionId,
        OptionKey? SelectedOption,
        decimal? NumericValue,
        Guid ClientRequestId,
        int RetryAttempt,
        DateTimeOffset NextAttemptAtUtc);

    private void StartHeartbeatTimer()
    {
        StopHeartbeatTimer();

        if (!SessionId.HasValue || identity is null)
        {
            return;
        }

        heartbeatTimer = new System.Threading.Timer(_ =>
        {
            _ = InvokeAsync(SendHeartbeatAsync);
        }, null, TimeSpan.FromSeconds(10), TimeSpan.FromSeconds(10));
    }

    private void StopHeartbeatTimer()
    {
        heartbeatTimer?.Dispose();
        heartbeatTimer = null;
        isHeartbeatInFlight = false;
    }

    private async Task SendHeartbeatAsync()
    {
        if (!SessionId.HasValue || identity is null || isHeartbeatInFlight)
        {
            return;
        }

        isHeartbeatInFlight = true;
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Post, $"/api/sessions/{SessionId.Value}/heartbeat/team?teamId={identity.TeamId}");
            request.Headers.Add("X-Team-Reconnect-Token", identity.TeamReconnectToken);
            await HttpClient.SendAsync(request);
        }
        finally
        {
            isHeartbeatInFlight = false;
        }
    }

    private void UpdateActiveSessionState()
    {
        if (identity is not null && snapshot is not null && snapshot.Status is SessionStatus.Waiting or SessionStatus.Running or SessionStatus.Paused)
        {
            var capturedIdentity = identity;
            ActiveSessionState.Set("Opravdu chcete opustit hru? Váš tým bude odhlášen ze session.", async () =>
            {
                using var request = new HttpRequestMessage(HttpMethod.Delete, $"/api/sessions/{capturedIdentity.SessionId}/teams/{capturedIdentity.TeamId}");
                request.Headers.Add("X-Team-Reconnect-Token", capturedIdentity.TeamReconnectToken);

                using var response = await HttpClient.SendAsync(request);
                if (response.IsSuccessStatusCode)
                {
                    await TeamSessionLocalStore.RemoveIdentityAsync(capturedIdentity.SessionId, capturedIdentity.TeamId);
                }
            });
        }
        else
        {
            ActiveSessionState.Clear();
        }
    }
}
